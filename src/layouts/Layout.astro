---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalUrl?: string;
  robots?: string;
}

const {
  title,
  description = 'Compare OpenClaw alternatives and forks side by side — GitHub stars, language, performance, and project health. The complete registry of the OpenClaw ecosystem.',
  ogImage = 'https://shelldex.com/images/og-default.jpg',
  ogImageAlt = 'Shelldex social preview image',
  canonicalUrl,
  robots = 'index, follow',
} = Astro.props;

const resolvedCanonical = canonicalUrl || `https://shelldex.com${Astro.url.pathname}`;

function inferImageType(url: string): string | undefined {
  const pathname = new URL(url).pathname.toLowerCase();
  if (pathname.endsWith('.png')) return 'image/png';
  if (pathname.endsWith('.webp')) return 'image/webp';
  if (pathname.endsWith('.jpg') || pathname.endsWith('.jpeg')) return 'image/jpeg';
  return undefined;
}

const ogImageType = inferImageType(ogImage);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/space-grotesk-latin.woff2" crossorigin />
    <link rel="prefetch" as="font" type="font/woff2" href="/fonts/titan-one-latin.woff2" crossorigin />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Shelldex — The OpenClaw Ecosystem" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    {ogImageType && <meta property="og:image:type" content={ogImageType} />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={resolvedCanonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:src" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- SEO -->
    <meta name="keywords" content="shelldex, clawdex, theclawdex, openclaw alternatives, openclaw clones, openclaw forks, openclaw comparison, zeroclaw, nanoclaw, picoclaw, ironclaw, moltis, nanobot, bashobot, nullclaw, openclaw-inspired projects, personal ai agent, agentic projects, self-hosted ai agent, open source ai assistant, clawdbot alternatives" />
    <meta name="robots" content={robots} />

    <title>{title}</title>
    <slot name="head" />
    <script is:inline>
      window.addEventListener('load', function() {
        setTimeout(function() {
          var s = document.createElement('script');
          s.src = 'https://metrics.dv.nu/api/script.js';
          s.setAttribute('data-site-id', '044ff383a31e');
          document.head.appendChild(s);
        }, 2000);
      });
    </script>
  </head>
  <body class="bg-ledger-bg text-ledger-text font-body antialiased min-h-screen flex flex-col overflow-x-hidden">
    <nav class="sticky top-0 z-50 bg-ledger-bg/90 backdrop-blur-md border-b border-ledger-border">
      <div class="max-w-[72rem] mx-auto px-5 sm:px-8">
        <div class="flex items-center justify-between h-14 sm:h-16">
          <a href="/" class="flex items-center gap-2.5 group">
            <span class="text-2xl group-hover:rotate-12 transition-transform duration-300">🦞</span>
            <span
              style="font-family: 'Titan One', sans-serif; letter-spacing: 0.04em;"
              class="text-xl text-ledger-red"
            >shelldex</span>
          </a>
          <div class="flex items-center gap-1">
            <div class="hidden sm:flex items-center">
              <a href="/" class="px-3 py-1.5 text-sm font-medium text-ledger-muted hover:text-ledger-red transition-colors rounded-md hover:bg-ledger-red-bg">Directory</a>
              <a href="/leaderboard/" class="px-3 py-1.5 text-sm font-medium text-ledger-muted hover:text-ledger-red transition-colors rounded-md hover:bg-ledger-red-bg">Leaderboard</a>
              <a href="/compare/" class="px-3 py-1.5 text-sm font-medium text-ledger-muted hover:text-ledger-red transition-colors rounded-md hover:bg-ledger-red-bg">Compare</a>
              <a href="/analysis/" class="px-3 py-1.5 text-sm font-medium text-ledger-muted hover:text-ledger-red transition-colors rounded-md hover:bg-ledger-red-bg">Analysis</a>
              <a href="/faq/" class="px-3 py-1.5 text-sm font-medium text-ledger-muted hover:text-ledger-red transition-colors rounded-md hover:bg-ledger-red-bg">FAQ</a>
              <a href="/best-alternatives/" class="px-3 py-1.5 text-sm font-medium text-ledger-muted hover:text-ledger-red transition-colors rounded-md hover:bg-ledger-red-bg">Alternatives</a>
              <a href="/about/" class="px-3 py-1.5 text-sm font-medium text-ledger-muted hover:text-ledger-red transition-colors rounded-md hover:bg-ledger-red-bg">About</a>
            </div>
            <div class="flex items-center gap-2 ml-2">
              <a
                href="/submit/"
                class="hidden sm:inline-flex items-center gap-1.5 px-3.5 py-1.5 text-sm font-semibold text-ledger-surface bg-ledger-red hover:bg-ledger-red-hover rounded-md transition-colors"
              >Submit</a>
              <a
                href="https://x.com/everyshell"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Shelldex on X"
                class="text-ledger-faint hover:text-ledger-text transition-colors flex items-center p-1.5"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932zM17.61 20.644h2.039L6.486 3.24H4.298z"/></svg>
              </a>
              <!-- Mobile hamburger -->
              <button
                id="mobile-menu-btn"
                type="button"
                aria-label="Toggle menu"
                aria-expanded="false"
                class="sm:hidden flex items-center justify-center w-9 h-9 text-ledger-muted hover:text-ledger-red transition-colors"
              >
                <svg id="menu-icon-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
          </div>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden sm:hidden border-t border-ledger-border pb-3 pt-1.5">
          <a href="/" class="block px-3 py-2 text-sm text-ledger-muted hover:text-ledger-red hover:bg-ledger-red-bg rounded-md">Directory</a>
          <a href="/leaderboard/" class="block px-3 py-2 text-sm text-ledger-muted hover:text-ledger-red hover:bg-ledger-red-bg rounded-md">Leaderboard</a>
          <a href="/compare/" class="block px-3 py-2 text-sm text-ledger-muted hover:text-ledger-red hover:bg-ledger-red-bg rounded-md">Compare</a>
          <a href="/analysis/" class="block px-3 py-2 text-sm text-ledger-muted hover:text-ledger-red hover:bg-ledger-red-bg rounded-md">Analysis</a>
          <a href="/faq/" class="block px-3 py-2 text-sm text-ledger-muted hover:text-ledger-red hover:bg-ledger-red-bg rounded-md">FAQ</a>
          <a href="/best-alternatives/" class="block px-3 py-2 text-sm text-ledger-muted hover:text-ledger-red hover:bg-ledger-red-bg rounded-md">Alternatives</a>
          <a href="/about/" class="block px-3 py-2 text-sm text-ledger-muted hover:text-ledger-red hover:bg-ledger-red-bg rounded-md">About</a>
          <a href="/submit/" class="block px-3 py-2 text-sm font-semibold text-ledger-red hover:bg-ledger-red-bg rounded-md">Submit a Project</a>
        </div>
      </div>
      <script is:inline>
        (function() {
          var btn = document.getElementById('mobile-menu-btn');
          var menu = document.getElementById('mobile-menu');
          var iconOpen = document.getElementById('menu-icon-open');
          var iconClose = document.getElementById('menu-icon-close');
          if (btn && menu && iconOpen && iconClose) {
            btn.addEventListener('click', function() {
              var expanded = btn.getAttribute('aria-expanded') === 'true';
              btn.setAttribute('aria-expanded', String(!expanded));
              menu.classList.toggle('hidden');
              iconOpen.classList.toggle('hidden');
              iconClose.classList.toggle('hidden');
            });
          }
        })();
      </script>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-ledger-border mt-16">
      <div class="max-w-[72rem] mx-auto px-5 sm:px-8 py-10 sm:py-14">
        <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-8 items-start">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-lg">🦞</span>
              <span style="font-family: 'Titan One', sans-serif; letter-spacing: 0.04em;" class="text-ledger-red">shelldex</span>
            </div>
            <p class="text-sm text-ledger-faint italic max-w-xs" id="footer-tagline">Every shell in the sea.</p>
            <script is:inline>
              (function() {
                var taglines = [
                  'Every shell in the sea.',
                  'Cataloging the ecosystem before it molts again.',
                  'Somebody had to keep track. We drew the short claw.',
                  'None of these are affiliated with actual lobsters. Probably.',
                ];
                var el = document.getElementById('footer-tagline');
                if (el) el.textContent = taglines[Math.floor(Math.random() * taglines.length)];
              })();
            </script>
          </div>
          <nav class="flex flex-wrap gap-x-6 gap-y-1.5 text-sm text-ledger-faint">
            <a href="/" class="hover:text-ledger-red transition-colors">Directory</a>
            <a href="/leaderboard/" class="hover:text-ledger-red transition-colors">Leaderboard</a>
            <a href="/compare/" class="hover:text-ledger-red transition-colors">Compare</a>
            <a href="/analysis/" class="hover:text-ledger-red transition-colors">Analysis</a>
            <a href="/about/" class="hover:text-ledger-red transition-colors">About</a>
            <a href="/submit/" class="hover:text-ledger-red transition-colors">Submit</a>
          </nav>
        </div>
        <div class="border-t border-ledger-border mt-8 pt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
          <p class="text-xs text-ledger-whisper">
            A project by <a href="https://onk.io" class="underline decoration-ledger-border hover:text-ledger-red transition-colors">Dave Onkels</a>.
            Inspired by <a href="https://github.com/openclaw/openclaw" class="underline decoration-ledger-border hover:text-ledger-red transition-colors">OpenClaw</a>.
          </p>
          <p class="text-xs text-ledger-whisper">
            <span id="rebrand-days" class="text-ledger-red font-mono">?</span> days since OpenClaw's last identity crisis.
          </p>
          <script is:inline>
            (function() {
              var lastRebrand = new Date('2026-01-29');
              var days = Math.floor((Date.now() - lastRebrand.getTime()) / 86400000);
              var el = document.getElementById('rebrand-days');
              if (el) el.textContent = days;
            })();
          </script>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/fonts.css';
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #f8f4ed; }
  ::-webkit-scrollbar-thumb { background: #d4c8ba; border-radius: 999px; }
  ::-webkit-scrollbar-thumb:hover { background: #c73b20; }

  ::selection {
    background: rgba(199, 59, 32, 0.15);
    color: #1c1410;
  }

  .v2-ticker-track {
    display: flex;
    gap: 0.5rem;
    width: max-content;
    animation: v2-ticker 60s linear infinite;
    will-change: transform;
  }
  @keyframes v2-ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .v2-ticker-track { animation-play-state: paused; }
  }
</style>
