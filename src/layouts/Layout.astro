---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The complete directory of OpenClaw clones, forks, and alternatives. Compare ZeroClaw, NanoClaw, PicoClaw, IronClaw, and more.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={`https://theclawdex.com${Astro.url.pathname}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://theclawdex.com${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Clawdex" />
    <meta property="og:image" content="https://theclawdex.com/images/og-default.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://theclawdex.com/images/og-default.png" />

    <!-- SEO -->
    <meta name="keywords" content="openclaw alternatives, openclaw clones, openclaw forks, zeroclaw, nanoclaw, picoclaw, ironclaw, moltis, nanobot, openclaw directory, clawdbot alternatives, moltbot alternatives, self-hosted ai agent, open source ai assistant" />
    <meta name="robots" content="index, follow" />

    <title>{title}</title>
    <script src="https://metrics.dv.nu/api/script.js" data-site-id="044ff383a31e" defer></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <nav class="sticky top-0 z-50 backdrop-blur-xl bg-ocean/80 border-b border-white/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2 group">
            <span class="text-2xl group-hover:animate-float">🦞</span>
            <span class="font-display font-bold text-xl text-white">Clawdex</span>
          </a>
          <div class="flex items-center gap-3 sm:gap-6">
            <a href="/" class="text-xs sm:text-sm leading-none text-gray-400 hover:text-biolum transition-colors">Directory</a>
            <a href="/about" class="text-xs sm:text-sm leading-none text-gray-400 hover:text-biolum transition-colors">About</a>
            <a href="/submit" class="text-xs sm:text-sm leading-none text-gray-400 hover:text-biolum transition-colors">Submit</a>
            <a
              href="https://github.com/daveonkels/clawdex"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-400 hover:text-white transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-white/5 mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xl">🦞</span>
              <span class="font-display font-bold text-white">Clawdex</span>
            </div>
            <p class="text-sm text-gray-500">Every shell in the sea.</p>
          </div>
          <div>
            <h3 class="font-display font-semibold text-white text-sm mb-3">Links</h3>
            <ul class="space-y-2 text-sm text-gray-500">
              <li><a href="/" class="hover:text-biolum transition-colors">Directory</a></li>
              <li><a href="/about" class="hover:text-biolum transition-colors">About</a></li>
              <li><a href="/submit" class="hover:text-biolum transition-colors">Submit a Project</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-display font-semibold text-white text-sm mb-3">Lobster Facts</h3>
            <ul class="space-y-2 text-sm text-gray-500" id="lobster-jokes">
              <li>Why don't lobsters share? They're shellfish.</li>
              <li>A lobster's blood is blue. Just like this site's theme.</li>
              <li>Lobsters taste with their feet. That's some sole food.</li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/5 mt-8 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs text-gray-600">Built with Astro, Tailwind, and crustacean energy. Not affiliated with actual lobsters.</p>
          <p class="text-xs text-gray-600">
            It has been <span id="rebrand-days" class="text-biolum font-mono">?</span> days since OpenClaw's last identity crisis.
          </p>
          <script is:inline>
            (function() {
              const lastRebrand = new Date('2026-01-29');
              const days = Math.floor((Date.now() - lastRebrand.getTime()) / 86400000);
              const el = document.getElementById('rebrand-days');
              if (el) el.textContent = days;
            })();
          </script>
        </div>
        <div class="border-t border-white/5 mt-6 pt-6 text-center">
          <p class="text-xs text-gray-600">
            Clawdex is a project by <a href="https://onk.io" class="text-gray-500 underline decoration-gray-700 hover:text-biolum transition-colors">Dave Onkels</a>, who is not a lobster. Inspired by <a href="https://github.com/openclaw/openclaw" class="text-gray-500 underline decoration-gray-700 hover:text-biolum transition-colors">OpenClaw</a> by <a href="https://steipete.com" class="text-gray-500 underline decoration-gray-700 hover:text-biolum transition-colors">Peter Steinberger</a>. Not affiliated with any crustaceans, living or autonomous.
          </p>
        </div>
      </div>
    </footer>
    <!-- Lobster Facts Toast -->
    <div id="lobster-toast" class="fixed bottom-6 right-6 max-w-xs bg-ocean-card border border-white/10 rounded-xl p-4 shadow-2xl shadow-black/40 transform translate-x-[120%] opacity-0 z-50" style="pointer-events: none; transition: transform 0.4s cubic-bezier(0.4,0,0.2,1), opacity 0.4s ease;">
      <div class="flex items-start gap-3">
        <span class="text-xl flex-shrink-0">🦞</span>
        <div>
          <p class="text-xs text-gray-500 font-mono uppercase tracking-wider mb-1">Lobster Fact</p>
          <p id="lobster-fact" class="text-sm text-gray-300 leading-relaxed"></p>
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        const facts = [
          "Lobsters pee from their faces. This has nothing to do with AI agents.",
          "A lobster's brain is roughly the size of a grasshopper's. Still shipped 228k stars.",
          "Lobsters can live to 100+. Most OpenClaw forks will not.",
          "Lobsters taste with their feet. Engineers taste with their opinions.",
          "A lobster's teeth are in its stomach. Its code reviews are similarly internal.",
          "Lobsters were once considered poverty food. OpenClaw was once called Clawdbot.",
          "Lobsters are biologically immortal. Their GitHub repos are not.",
          "Baby lobsters float for weeks before settling down. Much like early-stage startups.",
        ];
        const toast = document.getElementById('lobster-toast');
        const factEl = document.getElementById('lobster-fact');
        if (!toast || !factEl) return;

        var dismissTimer;
        function dismiss() {
          clearTimeout(dismissTimer);
          toast.style.transform = 'translateX(120%)';
          toast.style.opacity = '0';
          toast.style.pointerEvents = 'none';
        }

        // Touch swipe-right to dismiss
        var startX = 0;
        toast.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
        toast.addEventListener('touchmove', function(e) {
          var dx = e.touches[0].clientX - startX;
          if (dx > 0) toast.style.transform = 'translateX(' + dx + 'px)';
        }, { passive: true });
        toast.addEventListener('touchend', function(e) {
          var dx = e.changedTouches[0].clientX - startX;
          if (dx > 60) { dismiss(); } else { toast.style.transform = 'translateX(0)'; }
        });

        // Click to dismiss too
        toast.addEventListener('click', dismiss);
        toast.style.cursor = 'pointer';

        const delay = 3000 + Math.random() * 4000;
        setTimeout(function() {
          factEl.textContent = facts[Math.floor(Math.random() * facts.length)];
          toast.style.transform = 'translateX(0)';
          toast.style.opacity = '1';
          toast.style.pointerEvents = 'auto';
          dismissTimer = setTimeout(dismiss, 8000);
        }, delay);
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
