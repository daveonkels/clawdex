---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'The OpenClaw ecosystem, cataloged — clones, forks, derivatives, and alternatives. Compare by GitHub stars, language, and activity. Not workflows. Not tutorials. Just the projects.',
  ogImage = 'https://shelldex.com/images/og-default.jpg',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Titan+One&family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Titan+One&family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" /></noscript>
    <link rel="canonical" href={`https://shelldex.com${Astro.url.pathname}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://shelldex.com${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Shelldex — The OpenClaw Ecosystem" />
    <meta property="og:image" content="{ogImage}" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="{ogImage}" />

    <!-- SEO -->
    <meta name="keywords" content="shelldex, clawdex, theclawdex, openclaw alternatives, openclaw clones, openclaw forks, openclaw comparison, zeroclaw, nanoclaw, picoclaw, ironclaw, moltis, nanobot, bashobot, nullclaw, openclaw-inspired projects, personal ai agent, agentic projects, self-hosted ai agent, open source ai assistant, clawdbot alternatives" />
    <meta name="robots" content="index, follow" />

    <title>{title}</title>
    <script is:inline>
      window.addEventListener('load', function() {
        setTimeout(function() {
          var s = document.createElement('script');
          s.src = 'https://metrics.dv.nu/api/script.js';
          s.setAttribute('data-site-id', '044ff383a31e');
          document.head.appendChild(s);
        }, 2000);
      });
    </script>
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <!-- Bioluminescent background ambience -->
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden" aria-hidden="true">
      <!-- Large teal bloom — top right -->
      <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full animate-bio-drift"
           style="background: radial-gradient(circle, rgba(0,212,170,0.07) 0%, transparent 70%)"></div>
      <!-- Large teal bloom — bottom left -->
      <div class="absolute -bottom-40 -left-40 w-[700px] h-[700px] rounded-full animate-bio-drift-slow"
           style="background: radial-gradient(circle, rgba(0,212,170,0.06) 0%, transparent 70%)"></div>
      <!-- Lobster red pulse — mid right -->
      <div class="absolute top-1/2 -right-20 w-[300px] h-[300px] rounded-full animate-bio-drift"
           style="background: radial-gradient(circle, rgba(212,67,43,0.05) 0%, transparent 70%); animation-delay: -3s"></div>
      <!-- Small teal orb — lower center -->
      <div class="absolute bottom-1/4 left-1/3 w-[200px] h-[200px] rounded-full animate-bio-drift-slow"
           style="background: radial-gradient(circle, rgba(0,212,170,0.05) 0%, transparent 70%); animation-delay: -6s"></div>
      <!-- Tiny accent — top left -->
      <div class="absolute top-1/3 left-8 w-[120px] h-[120px] rounded-full animate-bio-drift"
           style="background: radial-gradient(circle, rgba(0,212,170,0.06) 0%, transparent 70%); animation-delay: -2s"></div>
    </div>
    <nav class="sticky top-0 z-50 backdrop-blur-xl bg-ocean/80 border-b border-white/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-center justify-between sm:h-16">
          <a href="/" class="flex items-center gap-2 group h-12 sm:h-16">
            <span class="text-2xl group-hover:animate-float">🦞</span>
            <span style="font-family: 'Titan One', sans-serif; font-weight: 400; font-style: normal; letter-spacing: 0.04em; background: linear-gradient(to right, #c73b20, #e8603a, #ff9a5c); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;" class="text-xl">shelldex</span>
          </a>
          <a
            href="https://github.com/daveonkels/clawdex"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Shelldex on GitHub"
            class="text-gray-400 hover:text-white transition-colors sm:order-last sm:ml-6 h-12 sm:h-16 flex items-center"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <div class="flex items-center gap-5 sm:gap-6 w-full sm:w-auto pb-3 sm:pb-0 border-t border-white/5 sm:border-0 pt-2 sm:pt-0">
            <a href="/" class="text-sm leading-none text-gray-400 hover:text-biolum transition-colors py-1">Directory</a>
            <a href="/leaderboard" class="text-sm leading-none text-gray-400 hover:text-biolum transition-colors py-1">Leaderboard</a>
            <a href="/about" class="text-sm leading-none text-gray-400 hover:text-biolum transition-colors py-1">About</a>
            <a href="/submit" class="text-sm leading-none text-gray-400 hover:text-biolum transition-colors py-1">Submit</a>
          </div>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-white/5 mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xl">🦞</span>
              <span style="font-family: 'Titan One', sans-serif; font-weight: 400; font-style: normal; letter-spacing: 0.04em; background: linear-gradient(to right, #c73b20, #e8603a, #ff9a5c); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">shelldex</span>
            </div>
            <p class="text-sm text-gray-500">Every shell in the sea.</p>
          </div>
          <div>
            <h3 class="font-display font-semibold text-white text-sm mb-3">Links</h3>
            <ul class="space-y-2 text-sm text-gray-500">
              <li><a href="/" class="hover:text-biolum transition-colors">Directory</a></li>
              <li><a href="/leaderboard" class="hover:text-biolum transition-colors">Leaderboard</a></li>
              <li><a href="/about" class="hover:text-biolum transition-colors">About</a></li>
              <li><a href="/submit" class="hover:text-biolum transition-colors">Submit a Project</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-display font-semibold text-white text-sm mb-3">Lobster Fact</h3>
            <p class="text-sm text-gray-500 leading-relaxed" id="lobster-fact-footer"></p>
            <script is:inline>
              (function() {
                var facts = [
                  "Why don't lobsters share? They're shellfish.",
                  "A lobster's blood is blue. Just like this site's theme.",
                  "Lobsters taste with their feet. That's some sole food.",
                  "Lobsters pee from their faces. This has nothing to do with AI agents.",
                  "A lobster's brain is roughly the size of a grasshopper's. Still shipped 228k stars.",
                  "Lobsters can live to 100+. Most OpenClaw forks will not.",
                  "A lobster's teeth are in its stomach. Its code reviews are similarly internal.",
                  "Lobsters were once considered poverty food. OpenClaw was once called Clawdbot.",
                  "Lobsters are biologically immortal. Their GitHub repos are not.",
                  "Baby lobsters float for weeks before settling down. Much like early-stage startups.",
                ];
                var el = document.getElementById('lobster-fact-footer');
                if (el) el.textContent = facts[Math.floor(Math.random() * facts.length)];
              })();
            </script>
          </div>
        </div>
        <div class="border-t border-white/5 mt-8 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs text-gray-600">Built with Astro, Tailwind, and crustacean energy. Not affiliated with actual lobsters or their claws.</p>
          <p class="text-xs text-gray-600">
            It has been <span id="rebrand-days" class="text-biolum font-mono">?</span> days since OpenClaw's last identity crisis.
          </p>
          <script is:inline>
            (function() {
              const lastRebrand = new Date('2026-01-29');
              const days = Math.floor((Date.now() - lastRebrand.getTime()) / 86400000);
              const el = document.getElementById('rebrand-days');
              if (el) el.textContent = days;
            })();
          </script>
        </div>
        <div class="border-t border-white/5 mt-6 pt-6 text-center">
          <p class="text-xs text-gray-600">
            Shelldex (formerly Clawdex) is a project by <a href="https://onk.io" class="text-gray-500 underline decoration-gray-700 hover:text-biolum transition-colors">Dave Onkels</a>, who is not a lobster. Inspired by <a href="https://github.com/openclaw/openclaw" class="text-gray-500 underline decoration-gray-700 hover:text-biolum transition-colors">OpenClaw</a> by <a href="https://steipete.com" class="text-gray-500 underline decoration-gray-700 hover:text-biolum transition-colors">Peter Steinberger</a>. Not affiliated with any crustaceans, living or autonomous.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
