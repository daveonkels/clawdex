---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

const leaderboardPath = path.join(process.cwd(), 'src', 'data', 'generated', 'leaderboard.json');

interface HealthIndicators {
  issues_stars_ratio: number;
  days_since_last_release: number | null;
  days_since_last_commit: number;
}

interface Entry {
  rank: number;
  name: string;
  slug: string;
  emoji: string;
  language: string;
  github: string;
  stars: number;
  forks: number;
  open_issues: number;
  star_growth_7d: number | null;
  latest_release: string | null;
  latest_release_date: string | null;
  last_commit: string;
  license: string | null;
  health: HealthIndicators;
}

interface Leaderboard {
  generated: string;
  count: number;
  entries: Entry[];
}

let leaderboard: Leaderboard = { generated: '', count: 0, entries: [] };
let hasData = false;

try {
  const raw = fs.readFileSync(leaderboardPath, 'utf-8');
  leaderboard = JSON.parse(raw);
  hasData = leaderboard.entries.length > 0;
} catch {
  // No leaderboard data yet — will show empty state
}

// ── Formatters ─────────────────────────────────────────────────────────────────
function formatStars(n: number): string {
  if (n >= 10000) return `${Math.round(n / 1000)}k`;
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
}

function formatGrowth(n: number | null): string {
  if (n === null) return '\u2014';
  if (n > 0) return `+${formatStars(n)}`;
  if (n === 0) return '0';
  return String(n);
}

function growthClass(n: number | null): string {
  if (n === null) return 'text-ledger-whisper';
  if (n > 0) return 'text-ledger-red';
  if (n < 0) return 'text-lobster-light';
  return 'text-ledger-faint';
}

function commitFreshness(days: number): string {
  if (days <= 7) return 'text-ledger-red';
  if (days <= 30) return 'text-ledger-muted';
  return 'text-ledger-whisper';
}

function healthDot(ratio: number): string {
  if (ratio < 0.01) return 'text-ledger-red';
  if (ratio < 0.05) return 'text-amber-700';
  return 'text-coral';
}

const langDot: Record<string, string> = {
  typescript: 'bg-blue-500', rust: 'bg-orange-500', python: 'bg-yellow-500',
  go: 'bg-cyan-600', c: 'bg-gray-500', bash: 'bg-green-600',
  zig: 'bg-amber-500', javascript: 'bg-yellow-400', kotlin: 'bg-purple-500',
  multi: 'bg-ledger-faint',
};
---

<Layout
  title={`OpenClaw Alternatives Ranked by Stars, Growth & Health (${new Date().getFullYear()}) | Shelldex`}
  description="GitHub stars leaderboard for OpenClaw ecosystem projects. Ranked by stars with growth trends and health indicators."
>
  {hasData && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "OpenClaw Ecosystem Leaderboard",
      "description": "GitHub stars leaderboard for OpenClaw ecosystem projects, ranked by popularity.",
      "numberOfItems": leaderboard.count,
      "itemListElement": leaderboard.entries.slice(0, 10).map((entry) => ({
        "@type": "ListItem",
        "position": entry.rank,
        "name": entry.name,
        "url": `https://shelldex.com/projects/${entry.slug}/`,
      })),
    })} />
  )}
  <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-3xl">🏆</span>
        <h1 class="text-3xl sm:text-4xl font-display font-bold text-ledger-text">
          Leaderboard
        </h1>
      </div>
      <p class="text-ledger-faint max-w-2xl">
        OpenClaw ecosystem ranked by GitHub stars, with growth trends and project health indicators.
      </p>
      {hasData && (
        <p class="text-xs text-ledger-whisper mt-2 font-mono">
          Updated {new Date(leaderboard.generated).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          &middot; {leaderboard.count} projects
        </p>
      )}
    </div>

    {!hasData ? (
      <!-- Empty state -->
      <div class="text-center py-20 border border-ledger-border rounded-2xl bg-ledger-surface">
        <span class="text-5xl mb-4 block">📊</span>
        <h2 class="text-xl font-display font-semibold text-ledger-text mb-2">Leaderboard data is being refreshed</h2>
        <p class="text-ledger-faint">Check back shortly — rankings update daily.</p>
      </div>
    ) : (
      <>
        <!-- Sort controls -->
        <div class="flex items-center gap-3 mb-6">
          <label for="lb-sort" class="text-sm text-ledger-faint">Sort by:</label>
          <select
            id="lb-sort"
            class="bg-ledger-surfaceer border border-ledger-border text-ledger-muted text-sm rounded-lg px-3 py-1.5 focus:border-ledger-red/50 focus:outline-none"
          >
            <option value="stars">Stars</option>
            <option value="growth">7-day Growth</option>
            <option value="name">Name A–Z</option>
            <option value="forks">Forks</option>
            <option value="issues">Open Issues</option>
            <option value="recent">Last Commit</option>
          </select>
        </div>

        <!-- ─── Desktop table ─────────────────────────────────────────────── -->
        <div class="hidden md:block overflow-x-auto rounded-xl border border-ledger-border bg-ledger-surface/80">
          <table class="w-full text-left" id="lb-table">
            <thead>
              <tr class="border-b border-ledger-border text-xs uppercase tracking-wider text-ledger-faint">
                <th class="py-3 px-4 w-12">#</th>
                <th class="py-3 px-4">Project</th>
                <th class="py-3 px-4 text-right cursor-pointer hover:text-ledger-red transition-colors" data-sort="stars">Stars&nbsp;↕</th>
                <th class="py-3 px-4 text-right cursor-pointer hover:text-ledger-red transition-colors" data-sort="growth">7d&nbsp;↕</th>
                <th class="py-3 px-4">Lang</th>
                <th class="py-3 px-4 text-right cursor-pointer hover:text-ledger-red transition-colors" data-sort="forks">Forks&nbsp;↕</th>
                <th class="py-3 px-4">Release</th>
                <th class="py-3 px-4 text-right cursor-pointer hover:text-ledger-red transition-colors" data-sort="recent">Commit&nbsp;↕</th>
                <th class="py-3 px-4 text-center" title="Issues/Stars health ratio">Health</th>
              </tr>
            </thead>
            <tbody id="lb-body">
              {leaderboard.entries.map((e) => (
                <tr
                  class="border-b border-ledger-border hover:bg-ledger-surfaceer/50 transition-colors lb-row"
                  data-stars={e.stars}
                  data-growth={e.star_growth_7d ?? -999999}
                  data-name={e.name.toLowerCase()}
                  data-forks={e.forks}
                  data-issues={e.open_issues}
                  data-last-commit={e.last_commit || '1970-01-01'}
                >
                  <td class="py-3 px-4 text-ledger-faint font-mono text-sm lb-rank">{e.rank}</td>
                  <td class="py-3 px-4">
                    <a href={`/projects/${e.slug}/`} class="group flex items-center gap-2">
                      <span class="text-lg">{e.emoji}</span>
                      <span class="text-ledger-text font-medium group-hover:text-ledger-red transition-colors">{e.name}</span>
                    </a>
                  </td>
                  <td class="py-3 px-4 text-right font-mono text-sm text-yellow-700">
                    ★ {formatStars(e.stars)}
                  </td>
                  <td class={`py-3 px-4 text-right font-mono text-sm ${growthClass(e.star_growth_7d)}`}>
                    {formatGrowth(e.star_growth_7d)}
                  </td>
                  <td class="py-3 px-4">
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-ledger-surface border border-ledger-border text-xs font-medium text-ledger-text">
                      <span class={`w-1.5 h-1.5 rounded-full ${langDot[e.language] || 'bg-ledger-faint'}`}></span>
                      {e.language}
                    </span>
                  </td>
                  <td class="py-3 px-4 text-right font-mono text-sm text-ledger-faint">
                    {formatStars(e.forks)}
                  </td>
                  <td class="py-3 px-4 text-sm text-ledger-faint">
                    {e.latest_release
                      ? <span class="font-mono">{e.latest_release}</span>
                      : <span class="text-ledger-whisper">&mdash;</span>}
                  </td>
                  <td class={`py-3 px-4 text-right text-sm ${commitFreshness(e.health.days_since_last_commit)}`}>
                    {e.health.days_since_last_commit < 999
                      ? `${e.health.days_since_last_commit}d ago`
                      : '\u2014'}
                  </td>
                  <td class="py-3 px-4 text-center">
                    <span
                      class={`text-sm ${healthDot(e.health.issues_stars_ratio)}`}
                      title={`Issues/Stars: ${e.health.issues_stars_ratio}`}
                    >●</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- ─── Mobile cards ──────────────────────────────────────────────── -->
        <div class="md:hidden space-y-3" id="lb-cards">
          {leaderboard.entries.map((e) => (
            <a
              href={`/projects/${e.slug}/`}
              class="block bg-ledger-surface border border-ledger-border rounded-xl p-4 hover:border-ledger-red/20 transition-all lb-card"
              data-stars={e.stars}
              data-growth={e.star_growth_7d ?? -999999}
              data-name={e.name.toLowerCase()}
              data-forks={e.forks}
              data-issues={e.open_issues}
              data-last-commit={e.last_commit || '1970-01-01'}
            >
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-2">
                  <span class="text-ledger-faint font-mono text-xs lb-rank">#{e.rank}</span>
                  <span class="text-lg">{e.emoji}</span>
                  <span class="text-ledger-text font-medium">{e.name}</span>
                </div>
                <span class="font-mono text-sm text-yellow-700">★ {formatStars(e.stars)}</span>
              </div>
              <div class="flex flex-wrap items-center gap-3 text-xs">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-ledger-surface border border-ledger-border text-xs font-medium text-ledger-text">
                  <span class={`w-1.5 h-1.5 rounded-full ${langDot[e.language] || 'bg-ledger-faint'}`}></span>
                  {e.language}
                </span>
                {e.star_growth_7d !== null && (
                  <span class={`font-mono ${growthClass(e.star_growth_7d)}`}>
                    {formatGrowth(e.star_growth_7d)} 7d
                  </span>
                )}
                {e.latest_release && (
                  <span class="text-ledger-faint font-mono">{e.latest_release}</span>
                )}
                <span class={`${commitFreshness(e.health.days_since_last_commit)}`}>
                  {e.health.days_since_last_commit < 999
                    ? `${e.health.days_since_last_commit}d ago`
                    : ''}
                </span>
              </div>
            </a>
          ))}
        </div>

        <!-- Legend -->
        <div class="mt-8 flex flex-wrap gap-6 text-xs text-ledger-faint">
          <div class="flex items-center gap-1.5">
            <span class="text-ledger-red">●</span> Healthy (&lt;1% issues/stars)
          </div>
          <div class="flex items-center gap-1.5">
            <span class="text-amber-700">●</span> Moderate (1–5%)
          </div>
          <div class="flex items-center gap-1.5">
            <span class="text-coral">●</span> Needs attention (&gt;5%)
          </div>
        </div>
      </>
    )}
  </section>

  <!-- Client-side sorting -->
  <script is:inline>
    (function () {
      var select = document.getElementById('lb-sort');
      var tbody = document.getElementById('lb-body');
      var cardsBox = document.getElementById('lb-cards');
      if (!select) return;

      function reorder(container, sel, cmp) {
        var items = Array.from(container.querySelectorAll(sel));
        items.sort(cmp);
        items.forEach(function (el, i) {
          container.appendChild(el);
          var rank = el.querySelector('.lb-rank');
          if (rank) rank.textContent = sel === '.lb-row' ? String(i + 1) : '#' + (i + 1);
        });
      }

      function comparator(key) {
        switch (key) {
          case 'stars':   return function (a, b) { return +b.dataset.stars - +a.dataset.stars; };
          case 'growth':  return function (a, b) { return +b.dataset.growth - +a.dataset.growth; };
          case 'name':    return function (a, b) { return a.dataset.name.localeCompare(b.dataset.name); };
          case 'forks':   return function (a, b) { return +b.dataset.forks - +a.dataset.forks; };
          case 'issues':  return function (a, b) { return +b.dataset.issues - +a.dataset.issues; };
          case 'recent':  return function (a, b) { return new Date(b.dataset.lastCommit) - new Date(a.dataset.lastCommit); };
          default:        return function (a, b) { return +b.dataset.stars - +a.dataset.stars; };
        }
      }

      select.addEventListener('change', function () {
        var cmp = comparator(this.value);
        if (tbody) reorder(tbody, '.lb-row', cmp);
        if (cardsBox) reorder(cardsBox, '.lb-card', cmp);
      });

      // Clickable column headers sync the dropdown
      document.querySelectorAll('th[data-sort]').forEach(function (th) {
        th.addEventListener('click', function () {
          select.value = this.dataset.sort;
          select.dispatchEvent(new Event('change'));
        });
      });
    })();
  </script>
</Layout>
