---
import Layout from '../layouts/Layout.astro';
import { loadProjects, formatStars } from '../lib/projects';
import { loadLeaderboard, computeHealthScore } from '../lib/compare';
import { languageColors } from '../lib/constants';

const projects = await loadProjects();
const { entries: leaderboard } = loadLeaderboard();
const projectCount = projects.length;

// Aggregate stats
const totalStars = leaderboard.reduce((s, e) => s + e.stars, 0);
const totalForks = leaderboard.reduce((s, e) => s + e.forks, 0);

// Language counts
const langCounts = new Map<string, number>();
for (const p of projects) {
  langCounts.set(p.language, (langCounts.get(p.language) || 0) + 1);
}
const langCountsSorted = [...langCounts.entries()].sort((a, b) => b[1] - a[1]);
const langCount = langCounts.size;

// Growth leaders (7d, positive only, sorted desc)
const growthLeaders = leaderboard
  .filter(e => (e.star_growth_7d ?? 0) > 0)
  .sort((a, b) => (b.star_growth_7d ?? 0) - (a.star_growth_7d ?? 0));
const maxGrowth = growthLeaders.length > 0 ? growthLeaders[0].star_growth_7d! : 1;

// Helper to look up stars by slug
function stars(slug: string): string {
  const entry = leaderboard.find(e => e.slug === slug);
  if (entry) return entry.stars.toLocaleString();
  const proj = projects.find(p => p.slug === slug);
  return (proj?.github_data?.stars ?? proj?.stars ?? 0).toLocaleString();
}

function starsK(slug: string): string {
  const entry = leaderboard.find(e => e.slug === slug);
  if (entry) return formatStars(entry.stars);
  const proj = projects.find(p => p.slug === slug);
  return formatStars(proj?.github_data?.stars ?? proj?.stars ?? 0);
}

function growth7d(slug: string): string {
  const entry = leaderboard.find(e => e.slug === slug);
  const g = entry?.star_growth_7d;
  if (g === null || g === undefined) return '--';
  return g > 0 ? `+${g.toLocaleString()}` : String(g);
}

function forks(slug: string): string {
  const entry = leaderboard.find(e => e.slug === slug);
  return (entry?.forks ?? 0).toLocaleString();
}

function license(slug: string): string {
  const entry = leaderboard.find(e => e.slug === slug);
  return entry?.license ?? '--';
}

function healthDot(slug: string): string {
  const entry = leaderboard.find(e => e.slug === slug);
  if (!entry) return 'text-gray-500';
  const ratio = entry.health.issues_stars_ratio;
  if (ratio < 0.01) return 'text-biolum';
  if (ratio < 0.05) return 'text-yellow-400';
  return 'text-coral';
}

// OpenClaw specific stats for decision tree
const oc = leaderboard.find(e => e.slug === 'openclaw');
const ocStars = oc ? oc.stars.toLocaleString() : '240,000+';
const ocForks = oc ? oc.forks.toLocaleString() : '46,000+';
const ocIssues = oc ? oc.open_issues.toLocaleString() : '9,000+';
const ocIssueRatio = oc ? (oc.health.issues_stars_ratio * 100).toFixed(2) : '~4';
const ocRelease = oc?.latest_release ?? '';

// Language color helper
const langColorMap: Record<string, { bg: string; text: string }> = {
  typescript: { bg: 'bg-blue-500/20', text: 'text-blue-300' },
  python: { bg: 'bg-yellow-500/20', text: 'text-yellow-300' },
  rust: { bg: 'bg-orange-500/20', text: 'text-orange-300' },
  go: { bg: 'bg-cyan-500/20', text: 'text-cyan-300' },
  c: { bg: 'bg-gray-500/20', text: 'text-gray-300' },
  zig: { bg: 'bg-amber-500/20', text: 'text-amber-300' },
  bash: { bg: 'bg-green-500/20', text: 'text-green-300' },
};
function langColor(lang: string): { bg: string; text: string } {
  return langColorMap[lang.toLowerCase()] ?? { bg: 'bg-gray-500/20', text: 'text-gray-300' };
}

// Bar chart colors for growth chart
const growthBarColors = [
  'from-biolum/80 to-biolum',   // 1st
  'from-biolum/80 to-biolum',   // 2nd
  'from-biolum/80 to-biolum',   // 3rd
  'from-coral/80 to-coral',     // 4th
  'from-coral/80 to-coral',     // 5th
  'from-lobster/80 to-lobster', // 6th
  'from-lobster/80 to-lobster', // 7th
  'from-lobster/80 to-lobster', // 8th+
];

// Language chart colors
const langBarColors: Record<string, string> = {
  typescript: 'bg-blue-500/60',
  python: 'bg-yellow-500/60',
  rust: 'bg-orange-500/60',
  go: 'bg-cyan-500/60',
  c: 'bg-gray-500/60',
  zig: 'bg-amber-500/60',
  bash: 'bg-green-500/60',
};

const maxLangCount = langCountsSorted.length > 0 ? langCountsSorted[0][1] : 1;
---

<Layout
  title={`OpenClaw Ecosystem: ${projectCount} Projects, ${langCount} Languages — Stats & Trends (${new Date().getFullYear()}) | Shelldex`}
  description={`A comprehensive data-driven analysis of ${projectCount} projects in the OpenClaw ecosystem. Compare stars, growth, languages, security models, and more across every clone, fork, and alternative.`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": `OpenClaw Ecosystem Analysis: ${projectCount} Projects Compared`,
    "description": `A comprehensive data-driven analysis of ${projectCount} projects in the OpenClaw ecosystem. Compare stars, growth, languages, security models, and more across every clone, fork, and alternative.`,
    "url": "https://shelldex.com/analysis/",
    "publisher": { "@type": "Organization", "name": "Shelldex", "url": "https://shelldex.com" }
  })} />

  <article class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- TITLE -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <header class="mb-16">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-white leading-tight mb-6">
        OpenClaw Ecosystem Analysis:<br class="hidden sm:block" />
        <span class="text-biolum">{projectCount} Projects</span> Compared
      </h1>
      <div class="h-px bg-gradient-to-r from-biolum/40 via-lobster/30 to-transparent"></div>
    </header>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- 1. EXECUTIVE SUMMARY -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <section class="mb-16">
      <h2 class="font-display text-3xl font-bold text-white mb-6">1. Executive Summary</h2>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        <div class="rounded-xl bg-ocean-card border border-white/5 p-5 text-center">
          <p class="text-3xl font-bold text-biolum font-mono">{projectCount}</p>
          <p class="text-xs text-gray-500 mt-1">Projects Tracked</p>
        </div>
        <div class="rounded-xl bg-ocean-card border border-white/5 p-5 text-center">
          <p class="text-3xl font-bold text-yellow-300 font-mono">{formatStars(totalStars)}</p>
          <p class="text-xs text-gray-500 mt-1">Total Stars</p>
        </div>
        <div class="rounded-xl bg-ocean-card border border-white/5 p-5 text-center">
          <p class="text-3xl font-bold text-coral font-mono">{formatStars(totalForks)}</p>
          <p class="text-xs text-gray-500 mt-1">Total Forks</p>
        </div>
        <div class="rounded-xl bg-ocean-card border border-white/5 p-5 text-center">
          <p class="text-3xl font-bold text-lobster font-mono">{langCount}</p>
          <p class="text-xs text-gray-500 mt-1">Languages</p>
        </div>
      </div>

      <div class="prose prose-invert max-w-none space-y-5 text-gray-300 leading-relaxed">
        <p>
          In less than two months, the <a href="/projects/openclaw/" class="text-biolum hover:text-biolum-light">OpenClaw</a> personal AI agent framework has spawned an ecosystem of {projectCount} distinct projects spanning {langCount} programming languages, four continents of contributors, and wildly divergent philosophies about what a personal AI agent should be. With a combined {totalStars.toLocaleString()} GitHub stars and over {totalForks.toLocaleString()} forks, the ecosystem has achieved a scale that most open-source communities take years to build. OpenClaw alone sits at {stars('openclaw')} stars, making it one of the fastest-growing repositories in GitHub history, but the real story is not the flagship project -- it is the constellation of clones, rewrites, and opinionated alternatives orbiting around it.
        </p>
        <p>
          The growth trajectory is striking. This week alone, <a href="/projects/openfang/" class="text-biolum hover:text-biolum-light">OpenFang</a> added {growth7d('openfang').replace('+', '')} stars, <a href="/projects/nullclaw/" class="text-biolum hover:text-biolum-light">NullClaw</a> gained {growth7d('nullclaw').replace('+', '')}, and <a href="/projects/zeroclaw/" class="text-biolum hover:text-biolum-light">ZeroClaw</a> picked up {growth7d('zeroclaw').replace('+', '')}. These are not marginal hobby projects coasting on reflected glory -- they are active codebases with daily commits, regular releases, and growing contributor bases. The ecosystem has passed the critical threshold where network effects begin to compound: developers are building tools for these clones, writing comparison guides, and choosing between them for production workloads.
        </p>
        <p>
          This analysis draws on live GitHub data collected by Shelldex's automated enrichment pipeline. Every number in this report comes from the <a href="/leaderboard/" class="text-biolum hover:text-biolum-light">leaderboard</a> dataset, updated daily. The goal is not to declare winners -- it is to map the terrain so that developers, teams, and organizations can make informed choices about which project fits their needs. Whether you want raw performance, security-hardened sandboxing, enterprise cloud deployment, or a learning agent that grows with you, there is now a project for that. The question is no longer "should I use OpenClaw?" but "which shell fits best?"
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- 2. TAXONOMY -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <section class="mb-16">
      <h2 class="font-display text-3xl font-bold text-white mb-6">2. Taxonomy -- Categories of Clones</h2>

      <p class="text-gray-300 leading-relaxed mb-8">
        Not all OpenClaw derivatives are trying to do the same thing. Some want to be smaller. Some want to be safer. Some want to run on Cloudflare Workers. To make sense of the landscape, we have grouped the {projectCount} tracked projects into six categories based on their primary design philosophy. A project can appear in multiple categories if its goals overlap, but each is listed under its most defining trait.
      </p>

      <!-- Tiny Claws -->
      <div class="rounded-xl bg-ocean-card border border-white/5 p-6 mb-6">
        <h3 class="font-display text-xl font-bold text-white mb-2">Tiny Claws -- Minimal & Lightweight</h3>
        <p class="text-gray-400 text-sm mb-4">
          These projects strip OpenClaw to its essentials. The premise is simple: the original codebase does too much. A personal AI agent should be a thin loop -- read context, call an LLM, execute tools, repeat. Everything else is overhead. The "tiny claws" category ranges from <a href="/projects/bashobot/" class="text-biolum hover:text-biolum-light">BashoBot</a>'s audacious Bash-only implementation to <a href="/projects/nanoclaw/" class="text-biolum hover:text-biolum-light">NanoClaw</a>'s {stars('nanoclaw')}-star TypeScript rewrite that proves minimalism can still attract a crowd. <a href="/projects/picoclaw/" class="text-biolum hover:text-biolum-light">PicoClaw</a>, written in Go, takes the embedded approach -- designed for edge devices and constrained environments where every megabyte counts.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/10 text-xs uppercase tracking-wider text-gray-500">
                <th class="py-2 px-3 text-left">Project</th>
                <th class="py-2 px-3 text-left">Language</th>
                <th class="py-2 px-3 text-right">Stars</th>
                <th class="py-2 px-3 text-left">Philosophy</th>
              </tr>
            </thead>
            <tbody class="text-gray-300">
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/nanoclaw/" class="text-biolum hover:text-biolum-light">NanoClaw</a></td><td class="py-2 px-3"><span class="bg-blue-500/20 text-blue-300 text-xs px-2 py-0.5 rounded-full">TypeScript</span></td><td class="py-2 px-3 text-right font-mono">{stars('nanoclaw')}</td><td class="py-2 px-3 text-gray-400">Minimal core, maximum extensibility</td></tr>
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/picoclaw/" class="text-biolum hover:text-biolum-light">PicoClaw</a></td><td class="py-2 px-3"><span class="bg-cyan-500/20 text-cyan-300 text-xs px-2 py-0.5 rounded-full">Go</span></td><td class="py-2 px-3 text-right font-mono">{stars('picoclaw')}</td><td class="py-2 px-3 text-gray-400">Edge-first, embedded-ready</td></tr>
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/microclaw/" class="text-biolum hover:text-biolum-light">MicroClaw</a></td><td class="py-2 px-3"><span class="bg-orange-500/20 text-orange-300 text-xs px-2 py-0.5 rounded-full">Rust</span></td><td class="py-2 px-3 text-right font-mono">{stars('microclaw')}</td><td class="py-2 px-3 text-gray-400">Tiny binary, single-file config</td></tr>
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/tinyclaw/" class="text-biolum hover:text-biolum-light">TinyClaw</a></td><td class="py-2 px-3"><span class="bg-blue-500/20 text-blue-300 text-xs px-2 py-0.5 rounded-full">TypeScript</span></td><td class="py-2 px-3 text-right font-mono">{stars('tinyclaw')}</td><td class="py-2 px-3 text-gray-400">Community-driven simplicity</td></tr>
              <tr><td class="py-2 px-3"><a href="/projects/bashobot/" class="text-biolum hover:text-biolum-light">BashoBot</a></td><td class="py-2 px-3"><span class="bg-green-500/20 text-green-300 text-xs px-2 py-0.5 rounded-full">Bash</span></td><td class="py-2 px-3 text-right font-mono">{stars('bashobot')}</td><td class="py-2 px-3 text-gray-400">Pure shell, zero dependencies</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Security-First -->
      <div class="rounded-xl bg-ocean-card border border-white/5 p-6 mb-6">
        <h3 class="font-display text-xl font-bold text-white mb-2">Security-First</h3>
        <p class="text-gray-400 text-sm mb-4">
          Giving an AI agent shell access to your machine is inherently dangerous. These projects treat security as the primary design constraint rather than an afterthought. <a href="/projects/ironclaw/" class="text-biolum hover:text-biolum-light">IronClaw</a> builds a Rust-based sandbox with capability-based permissions. <a href="/projects/safeclaw/" class="text-biolum hover:text-biolum-light">SafeClaw</a> wraps the Python ecosystem in guardrails. <a href="/projects/secure-openclaw/" class="text-biolum hover:text-biolum-light">Secure-OpenClaw</a> is a hardened fork of the original. And <a href="/projects/carapace/" class="text-biolum hover:text-biolum-light">Carapace</a> takes the Rust sandbox concept further with a full audit trail.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/10 text-xs uppercase tracking-wider text-gray-500">
                <th class="py-2 px-3 text-left">Project</th>
                <th class="py-2 px-3 text-left">Language</th>
                <th class="py-2 px-3 text-right">Stars</th>
                <th class="py-2 px-3 text-left">Security Model</th>
              </tr>
            </thead>
            <tbody class="text-gray-300">
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/ironclaw/" class="text-biolum hover:text-biolum-light">IronClaw</a></td><td class="py-2 px-3"><span class="bg-orange-500/20 text-orange-300 text-xs px-2 py-0.5 rounded-full">Rust</span></td><td class="py-2 px-3 text-right font-mono">{stars('ironclaw')}</td><td class="py-2 px-3 text-gray-400">Capability-based sandboxing</td></tr>
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/secure-openclaw/" class="text-biolum hover:text-biolum-light">Secure-OpenClaw</a></td><td class="py-2 px-3"><span class="bg-blue-500/20 text-blue-300 text-xs px-2 py-0.5 rounded-full">TypeScript</span></td><td class="py-2 px-3 text-right font-mono">{stars('secure-openclaw')}</td><td class="py-2 px-3 text-gray-400">Hardened fork with permission layers</td></tr>
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/safeclaw/" class="text-biolum hover:text-biolum-light">SafeClaw</a></td><td class="py-2 px-3"><span class="bg-yellow-500/20 text-yellow-300 text-xs px-2 py-0.5 rounded-full">Python</span></td><td class="py-2 px-3 text-right font-mono">{stars('safeclaw')}</td><td class="py-2 px-3 text-gray-400">Python guardrails and sandboxing</td></tr>
              <tr><td class="py-2 px-3"><a href="/projects/carapace/" class="text-biolum hover:text-biolum-light">Carapace</a></td><td class="py-2 px-3"><span class="bg-orange-500/20 text-orange-300 text-xs px-2 py-0.5 rounded-full">Rust</span></td><td class="py-2 px-3 text-right font-mono">{stars('carapace')}</td><td class="py-2 px-3 text-gray-400">Full audit trail, Rust sandbox</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Enterprise & Cloud -->
      <div class="rounded-xl bg-ocean-card border border-white/5 p-6 mb-6">
        <h3 class="font-display text-xl font-bold text-white mb-2">Enterprise & Cloud</h3>
        <p class="text-gray-400 text-sm mb-4">
          While most OpenClaw derivatives are designed for individual developers running agents on their laptops, this cluster targets teams and organizations. <a href="/projects/moltworker/" class="text-biolum hover:text-biolum-light">Moltworker</a>, built by Cloudflare, runs agents on Workers -- serverless, globally distributed, and managed. <a href="/projects/aionui/" class="text-biolum hover:text-biolum-light">AionUi</a> provides a full desktop and web interface for enterprise deployments. <a href="/projects/clawwork/" class="text-biolum hover:text-biolum-light">ClawWork</a> focuses on multi-agent orchestration for production workflows, and <a href="/projects/langbot/" class="text-biolum hover:text-biolum-light">LangBot</a> bridges the gap between AI agents and team messaging platforms.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/10 text-xs uppercase tracking-wider text-gray-500">
                <th class="py-2 px-3 text-left">Project</th>
                <th class="py-2 px-3 text-left">Language</th>
                <th class="py-2 px-3 text-right">Stars</th>
                <th class="py-2 px-3 text-left">Target</th>
              </tr>
            </thead>
            <tbody class="text-gray-300">
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/aionui/" class="text-biolum hover:text-biolum-light">AionUi</a></td><td class="py-2 px-3"><span class="bg-blue-500/20 text-blue-300 text-xs px-2 py-0.5 rounded-full">TypeScript</span></td><td class="py-2 px-3 text-right font-mono">{stars('aionui')}</td><td class="py-2 px-3 text-gray-400">Enterprise UI platform</td></tr>
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/langbot/" class="text-biolum hover:text-biolum-light">LangBot</a></td><td class="py-2 px-3"><span class="bg-yellow-500/20 text-yellow-300 text-xs px-2 py-0.5 rounded-full">Python</span></td><td class="py-2 px-3 text-right font-mono">{stars('langbot')}</td><td class="py-2 px-3 text-gray-400">Team messaging integration</td></tr>
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/moltworker/" class="text-biolum hover:text-biolum-light">Moltworker</a></td><td class="py-2 px-3"><span class="bg-blue-500/20 text-blue-300 text-xs px-2 py-0.5 rounded-full">TypeScript</span></td><td class="py-2 px-3 text-right font-mono">{stars('moltworker')}</td><td class="py-2 px-3 text-gray-400">Cloudflare Workers serverless</td></tr>
              <tr><td class="py-2 px-3"><a href="/projects/clawwork/" class="text-biolum hover:text-biolum-light">ClawWork</a></td><td class="py-2 px-3"><span class="bg-yellow-500/20 text-yellow-300 text-xs px-2 py-0.5 rounded-full">Python</span></td><td class="py-2 px-3 text-right font-mono">{stars('clawwork')}</td><td class="py-2 px-3 text-gray-400">Multi-agent orchestration</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Research & Memory -->
      <div class="rounded-xl bg-ocean-card border border-white/5 p-6 mb-6">
        <h3 class="font-display text-xl font-bold text-white mb-2">Research & Memory</h3>
        <p class="text-gray-400 text-sm mb-4">
          The most philosophically interesting corner of the ecosystem. These projects argue that a personal AI agent is only as good as its memory. <a href="/projects/nanobot/" class="text-biolum hover:text-biolum-light">Nanobot</a>, the second-most-starred project in the ecosystem at {stars('nanobot')} stars, is a research-grade agentic framework from HKUDS. <a href="/projects/memu/" class="text-biolum hover:text-biolum-light">memU</a> introduces multi-level persistent memory, and <a href="/projects/memos/" class="text-biolum hover:text-biolum-light">MemOS</a> takes the operating-system metaphor literally -- treating memory as a first-class managed resource. The newest entrant, <a href="/projects/hermes/" class="text-biolum hover:text-biolum-light">Hermes Agent</a> by Nous Research, builds self-authored skills and a growing knowledge base.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/10 text-xs uppercase tracking-wider text-gray-500">
                <th class="py-2 px-3 text-left">Project</th>
                <th class="py-2 px-3 text-left">Language</th>
                <th class="py-2 px-3 text-right">Stars</th>
                <th class="py-2 px-3 text-left">Memory Approach</th>
              </tr>
            </thead>
            <tbody class="text-gray-300">
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/nanobot/" class="text-biolum hover:text-biolum-light">Nanobot</a></td><td class="py-2 px-3"><span class="bg-yellow-500/20 text-yellow-300 text-xs px-2 py-0.5 rounded-full">Python</span></td><td class="py-2 px-3 text-right font-mono">{stars('nanobot')}</td><td class="py-2 px-3 text-gray-400">Research-grade agentic framework</td></tr>
              <tr class="border-b border-white/5"><td class="py-2 px-3"><a href="/projects/memu/" class="text-biolum hover:text-biolum-light">memU</a></td><td class="py-2 px-3"><span class="bg-yellow-500/20 text-yellow-300 text-xs px-2 py-0.5 rounded-full">Python</span></td><td class="py-2 px-3 text-right font-mono">{stars('memu')}</td><td class="py-2 px-3 text-gray-400">Multi-level persistent memory</td></tr>
