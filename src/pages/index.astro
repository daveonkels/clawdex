---
import Layout from '../layouts/Layout.astro';
import { loadProjects, getUniqueLanguages, formatStars } from '../lib/projects';
import { loadLeaderboard, getIndexableComparePairs } from '../lib/compare';
import fs from 'node:fs';

const projects = await loadProjects();
const languages = getUniqueLanguages(projects);

// Momentum ticker data
const leaderboard = loadLeaderboard();
const movers = leaderboard.entries
  .filter(e => e.star_growth_7d && e.star_growth_7d > 0)
  .sort((a, b) => (b.star_growth_7d ?? 0) - (a.star_growth_7d ?? 0));
const lbRaw = JSON.parse(fs.readFileSync('src/data/generated/leaderboard.json', 'utf-8'));
const generatedDate = new Date(lbRaw.generated);

// Top comparison pairs
const indexablePairs = getIndexableComparePairs(projects);
const projectMap = new Map(projects.map(p => [p.slug, p]));
const topComparePairs = indexablePairs.slice(0, 12);

// Tiers
const featured = projects.slice(0, 5);
const directory = projects.slice(5);

// Stats for hero
const totalStars = projects.reduce((sum, p) => sum + (p.stars ?? 0), 0);
const uniqueLangs = new Set(projects.map(p => p.language)).size;
const topGrowth = movers[0];

// Updated label
const now = new Date();
const diffMs = now.getTime() - generatedDate.getTime();
const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
const updatedLabel = diffHours < 1 ? 'just now' : diffHours < 24 ? `${diffHours}h ago` : `${Math.floor(diffMs / (1000 * 60 * 60 * 24))}d ago`;

// Language dot colors
const langDot: Record<string, string> = {
  typescript: 'bg-blue-500',
  rust: 'bg-orange-500',
  python: 'bg-yellow-500',
  go: 'bg-cyan-600',
  c: 'bg-gray-500',
  bash: 'bg-green-600',
  zig: 'bg-amber-500',
  javascript: 'bg-yellow-400',
  kotlin: 'bg-purple-500',
  multi: 'bg-ledger-faint',
};
---

<Layout title={`OpenClaw Ecosystem: ${projects.length} Projects Compared | Shelldex`}>

  {/* ── Trending Bar ── */}
  {movers.length > 0 && (
    <div class="border-b border-ledger-border bg-ledger-surface">
      <div class="max-w-[72rem] mx-auto px-5 sm:px-8 py-3">
        <div class="flex items-center gap-3">
          <span class="text-[10px] font-mono uppercase tracking-widest text-ledger-faint shrink-0">Trending</span>
          <div class="relative flex-1 min-w-0">
            <div class="absolute inset-y-0 right-0 w-12 z-10 pointer-events-none bg-gradient-to-l from-ledger-surface to-transparent"></div>
            <div class="flex gap-2 overflow-x-auto trending-scroll pr-12">
              {movers.slice(0, 8).map(m => {
                const proj = projects.find(p => p.name === m.name);
                return (
                  <a
                    href={proj ? `/projects/${proj.slug}/` : '#'}
                    class="shrink-0 flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-ledger-border bg-ledger-hover hover:border-ledger-border-strong transition-colors text-sm"
                  >
                    {proj?.emoji && <span>{proj.emoji}</span>}
                    <span class="font-medium text-ledger-text">{m.name}</span>
                    <span class="font-mono text-ledger-red text-xs font-bold">+{formatStars(m.star_growth_7d ?? 0)}</span>
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </div>
  )}

  {/* ── Hero ── */}
  <section class="max-w-[72rem] mx-auto px-5 sm:px-8 pt-12 sm:pt-20 pb-10 sm:pb-16">
    <div class="grid lg:grid-cols-[1fr_280px] gap-8 lg:gap-16 items-start">
      <div>
        <h1 class="font-display text-[clamp(2.8rem,7vw,5.5rem)] font-bold leading-[0.92] tracking-[-0.03em] text-ledger-text mb-6">
          Every shell<br/>in the sea<span class="text-ledger-red">.</span>
        </h1>
        <p class="text-lg sm:text-xl text-ledger-muted max-w-lg leading-relaxed mb-8">
          The complete registry of OpenClaw clones, forks, and alternatives. {projects.length} projects tracked by stars, growth, and health.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="#directory"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-ledger-red text-ledger-surface font-semibold rounded-md hover:bg-ledger-red-hover transition-colors text-sm"
          >
            Browse the registry
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </a>
          <a href="/submit/" class="text-sm text-ledger-faint hover:text-ledger-red transition-colors">
            Submit a project &rarr;
          </a>
        </div>
      </div>
      <aside class="lg:mt-6">
        <div class="grid grid-cols-2 lg:grid-cols-1 gap-4 lg:gap-5">
          <div>
            <div class="font-mono text-3xl sm:text-4xl font-bold text-ledger-text tracking-tight">{projects.length}</div>
            <div class="text-xs text-ledger-faint uppercase tracking-wider mt-0.5">Projects tracked</div>
          </div>
          <div>
            <div class="font-mono text-3xl sm:text-4xl font-bold text-ledger-text tracking-tight">{formatStars(totalStars)}</div>
            <div class="text-xs text-ledger-faint uppercase tracking-wider mt-0.5">Combined stars</div>
          </div>
          <div>
            <div class="font-mono text-3xl sm:text-4xl font-bold text-ledger-text tracking-tight">{uniqueLangs}</div>
            <div class="text-xs text-ledger-faint uppercase tracking-wider mt-0.5">Languages</div>
          </div>
          {topGrowth && (
            <div>
              <div class="font-mono text-3xl sm:text-4xl font-bold text-ledger-red tracking-tight">+{topGrowth.star_growth_7d?.toLocaleString()}</div>
              <div class="text-xs text-ledger-faint uppercase tracking-wider mt-0.5">{topGrowth.name} this week</div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </section>

  {/* ── Headliners ── */}
  <section class="max-w-[72rem] mx-auto px-5 sm:px-8 pb-14">
    <div class="flex items-center gap-4 mb-10">
      <span class="text-xs tracking-[0.25em] uppercase font-bold text-ledger-red whitespace-nowrap">Headliners</span>
      <div class="flex-1 h-[3px] bg-ledger-red"></div>
    </div>

    <div class="space-y-0">
      {featured.map((p, i) => {
        const rank = String(i + 1).padStart(2, '0');
        const growth = movers.find(m => m.slug === p.slug);
        return (
          <a href={`/projects/${p.slug}/`} class="group flex items-center gap-4 sm:gap-6 py-6 border-b-2 border-ledger-border hover:bg-ledger-hover transition-colors">
            <span class="text-[3rem] sm:text-[4rem] font-mono font-bold text-ledger-red/20 leading-none group-hover:text-ledger-red transition-colors w-16 sm:w-24 text-right shrink-0">
              {rank}
            </span>
            <span class="text-3xl sm:text-4xl shrink-0">{p.emoji}</span>
            <div class="flex-1 min-w-0">
              <div class="font-display text-xl sm:text-2xl font-bold text-ledger-text">{p.name}</div>
              <div class="text-ledger-faint text-sm truncate">{p.tagline}</div>
            </div>
            <div class="text-right shrink-0">
              <div class="font-mono text-2xl sm:text-3xl font-bold text-ledger-text tabular-nums">{formatStars(p.stars ?? 0)}</div>
              {growth?.star_growth_7d && growth.star_growth_7d > 0 && (
                <div class="text-ledger-red text-xs font-mono">+{formatStars(growth.star_growth_7d)} /wk</div>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </section>

  {/* ── Full Registry ── */}
  <section id="directory" class="max-w-[72rem] mx-auto px-5 sm:px-8 pb-16">
    <div class="flex items-baseline gap-3 mb-5">
      <h2 class="font-display text-sm font-bold text-ledger-red uppercase tracking-widest">Full Registry</h2>
      <span class="text-xs text-ledger-faint font-mono" id="v2-results-count">{directory.length} more</span>
      <div class="flex-1 border-t border-ledger-border"></div>
    </div>

    {/* Filters: single row */}
    <div class="flex flex-col sm:flex-row gap-3 mb-6" id="v2-filter-bar">
      <div class="relative flex-1 max-w-sm">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ledger-whisper" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input
          type="text"
          id="v2-search"
          placeholder="Search..."
          class="w-full pl-9 pr-3 py-2 bg-ledger-surface border border-ledger-border rounded-md text-sm text-ledger-text placeholder-ledger-whisper focus:outline-none focus:border-ledger-red/40 focus:ring-1 focus:ring-ledger-red/20 transition-all"
        />
      </div>
      <div class="flex flex-wrap items-center gap-1.5" id="v2-lang-filters">
        <button class="v2-lang-btn v2-lang-active" data-lang="all">All</button>
        {languages.map(lang => (
          <button class="v2-lang-btn" data-lang={lang}>
            <span class={`inline-block w-1.5 h-1.5 rounded-full ${langDot[lang] || 'bg-ledger-faint'} mr-1`}></span>
            {lang}
          </button>
        ))}
      </div>
      <select id="v2-sort" aria-label="Sort" class="bg-ledger-surface border border-ledger-border rounded-md text-sm text-ledger-muted px-2.5 py-2 focus:outline-none focus:border-ledger-red/40 cursor-pointer">
        <option value="stars">Stars</option>
        <option value="name">A-Z</option>
        <option value="recent">Recent</option>
      </select>
    </div>

    {/* Compact list */}
    <div class="border border-ledger-border rounded-lg bg-ledger-surface overflow-hidden" id="v2-project-list">
      {directory.map((p, i) => {
        const growth = movers.find(m => m.slug === p.slug);
        return (
          <a
            href={`/projects/${p.slug}/`}
            class={`v2-row group flex items-center gap-3 sm:gap-4 px-4 sm:px-5 py-3 sm:py-3.5 hover:bg-ledger-hover transition-colors ${i < directory.length - 1 ? 'border-b border-ledger-border/60' : ''}`}
            data-language={p.language}
            data-status={p.status}
            data-stars={p.stars ?? 0}
            data-name={p.name}
            data-added={p.added ?? ''}
          >
            <span class="text-xl sm:text-2xl shrink-0 w-8 text-center">{p.emoji}</span>
            <div class="flex-1 min-w-0 flex flex-col sm:flex-row sm:items-center gap-0.5 sm:gap-3">
              <span class="font-display font-semibold text-ledger-text group-hover:text-ledger-red transition-colors whitespace-nowrap">{p.name}</span>
              <span class="text-sm text-ledger-faint truncate hidden sm:inline">{p.tagline}</span>
            </div>
            <div class="flex items-center gap-3 sm:gap-4 shrink-0">
              {p.mcp_support && (
                <span class="text-[10px] font-bold text-ledger-teal uppercase tracking-wider hidden sm:inline">MCP</span>
              )}
              <span class="inline-flex items-center gap-1 text-xs font-mono text-ledger-faint">
                <span class={`w-1.5 h-1.5 rounded-full ${langDot[p.language] || 'bg-ledger-faint'}`}></span>
                <span class="hidden sm:inline">{p.language}</span>
              </span>
              {growth && growth.star_growth_7d && growth.star_growth_7d > 0 && (
                <span class="font-mono text-[11px] text-ledger-red tabular-nums hidden md:inline">+{growth.star_growth_7d.toLocaleString()}</span>
              )}
              <span class="font-mono text-sm text-ledger-text tabular-nums w-14 text-right">{formatStars(p.stars ?? 0)} <span class="text-ledger-coral text-xs">&#9733;</span></span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  {/* ── Popular Comparisons ── */}
  <section class="max-w-[72rem] mx-auto px-5 sm:px-8 pb-12">
    <div class="flex items-baseline gap-3 mb-5">
      <h2 class="font-display text-sm font-bold text-ledger-red uppercase tracking-widest">Comparisons</h2>
      <a href="/compare/" class="text-xs text-ledger-faint hover:text-ledger-red transition-colors ml-auto">
        All {indexablePairs.length} comparisons &rarr;
      </a>
      <div class="flex-1 border-t border-ledger-border max-w-[30%]"></div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
      {topComparePairs.map((pair) => (
        <a
          href={`/compare/${pair.canonical}/`}
          class="flex items-center gap-2 rounded-md border border-ledger-border bg-ledger-surface px-3 py-2.5 text-sm text-ledger-muted hover:text-ledger-red hover:border-ledger-red/20 hover:bg-ledger-red-bg transition-all"
        >
          <span class="shrink-0">{projectMap.get(pair.slugA)?.emoji}</span>
          <span class="truncate">{projectMap.get(pair.slugA)?.name} vs {projectMap.get(pair.slugB)?.name}</span>
          <span class="shrink-0">{projectMap.get(pair.slugB)?.emoji}</span>
        </a>
      ))}
    </div>
  </section>

  {/* ── Explore ── */}
  <section class="max-w-[72rem] mx-auto px-5 sm:px-8 pb-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
      <a href="/compare/" class="group rounded-md border border-ledger-border bg-ledger-surface p-4 hover:border-ledger-red/30 hover:bg-ledger-red-bg transition-all">
        <p class="font-display font-semibold text-sm text-ledger-text group-hover:text-ledger-red transition-colors">Compare</p>
        <p class="text-xs text-ledger-faint mt-0.5">{Math.round(projects.length * (projects.length - 1) / 2)}+ pairs</p>
      </a>
      <a href="/leaderboard/" class="group rounded-md border border-ledger-border bg-ledger-surface p-4 hover:border-ledger-red/30 hover:bg-ledger-red-bg transition-all">
        <p class="font-display font-semibold text-sm text-ledger-text group-hover:text-ledger-red transition-colors">Leaderboard</p>
        <p class="text-xs text-ledger-faint mt-0.5">Stars, growth, health</p>
      </a>
      <a href="/best-alternatives/" class="group rounded-md border border-ledger-border bg-ledger-surface p-4 hover:border-ledger-red/30 hover:bg-ledger-red-bg transition-all">
        <p class="font-display font-semibold text-sm text-ledger-text group-hover:text-ledger-red transition-colors">Alternatives</p>
        <p class="text-xs text-ledger-faint mt-0.5">Ranked with pros & cons</p>
      </a>
      <a href="/analysis/" class="group rounded-md border border-ledger-border bg-ledger-surface p-4 hover:border-ledger-red/30 hover:bg-ledger-red-bg transition-all">
        <p class="font-display font-semibold text-sm text-ledger-text group-hover:text-ledger-red transition-colors">Analysis</p>
        <p class="text-xs text-ledger-faint mt-0.5">Trends & distribution</p>
      </a>
    </div>
  </section>

</Layout>

<style>
  .v2-lang-btn {
    @apply inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium transition-all border border-transparent;
    color: theme('colors.ledger.faint');
  }
  .v2-lang-btn:hover {
    color: theme('colors.ledger.red');
    background: theme('colors.ledger.red-bg');
  }
  .trending-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .trending-scroll::-webkit-scrollbar {
    display: none;
  }
  .v2-lang-active {
    color: theme('colors.ledger.red') !important;
    background: theme('colors.ledger.red-bg');
    border-color: theme('colors.ledger.red / 20%');
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('v2-search') as HTMLInputElement;
    const sortSelect = document.getElementById('v2-sort') as HTMLSelectElement;
    const rows = document.querySelectorAll<HTMLElement>('.v2-row');
    const langBtns = document.querySelectorAll<HTMLButtonElement>('.v2-lang-btn');
    const countEl = document.getElementById('v2-results-count');

    let activeLang = 'all';
    let searchQuery = '';

    function applyFilters() {
      let visible = 0;
      rows.forEach(row => {
        const lang = row.dataset.language || '';
        const text = row.textContent?.toLowerCase() || '';
        const matchLang = activeLang === 'all' || lang === activeLang;
        const matchSearch = !searchQuery || text.includes(searchQuery.toLowerCase());
        const show = matchLang && matchSearch;
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (countEl) countEl.textContent = `${visible} more`;
    }

    function sortRows() {
      const list = document.getElementById('v2-project-list')!;
      const sorted = Array.from(rows).sort((a, b) => {
        switch (sortSelect?.value) {
          case 'stars':
            return (parseInt(b.dataset.stars || '0')) - (parseInt(a.dataset.stars || '0'));
          case 'name':
            return (a.dataset.name || '').localeCompare(b.dataset.name || '');
          case 'recent':
            return (b.dataset.added || '').localeCompare(a.dataset.added || '');
          default:
            return 0;
        }
      });
      sorted.forEach(r => list.appendChild(r));
    }

    langBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        langBtns.forEach(b => b.classList.remove('v2-lang-active'));
        btn.classList.add('v2-lang-active');
        activeLang = btn.dataset.lang || 'all';
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', () => {
      searchQuery = searchInput.value;
      applyFilters();
    });

    sortSelect?.addEventListener('change', () => {
      sortRows();
    });
  });
</script>
