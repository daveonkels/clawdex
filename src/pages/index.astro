---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FilterBar from '../components/FilterBar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { loadProjects, getUniqueLanguages, getUniqueTiers, getUniqueStatuses } from '../lib/projects';

const projects = await loadProjects();
const languages = getUniqueLanguages(projects);
const tiers = getUniqueTiers(projects);
const statuses = getUniqueStatuses(projects);
const categories = [...new Set(projects.flatMap(p => p.category))].sort();
---

<Layout title="Clawdex — OpenClaw Ecosystem Tracker | Framework Directory">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Clawdex — OpenClaw Ecosystem Tracker",
    "url": "https://theclawdex.com",
    "description": "The OpenClaw ecosystem tracker. Compare frameworks, forks, and alternatives by GitHub stars, language, and activity. A framework directory, not a workflow gallery.",
    "about": {
      "@type": "SoftwareApplication",
      "name": "OpenClaw",
      "url": "https://github.com/openclaw/openclaw"
    },
    "keywords": "openclaw alternatives, openclaw forks, openclaw ecosystem, openclaw comparison, self-hosted AI agent comparison",
    "creator": {
      "@type": "Person",
      "name": "Dave Onkels",
      "url": "https://onk.io"
    }
  })} />
  <Hero projectCount={projects.length} />

  <section id="directory" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-display text-2xl font-bold text-white">Directory</h2>
      <span id="results-count" class="text-sm text-gray-500">{projects.length} projects</span>
    </div>

    <FilterBar
      languages={languages}
      categories={categories}
      tiers={tiers}
      statuses={statuses}
    />

    <div id="project-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map(project => (
        <ProjectCard
          name={project.name}
          slug={project.slug}
          tagline={project.tagline}
          description={project.description}
          language={project.language}
          category={project.category}
          github={project.github}
          status={project.status}
          tier={project.tier}
          highlight={project.highlight}
          emoji={project.emoji}
          stars={project.stars}
          added={project.added}
        />
      ))}
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
    const grid = document.getElementById('project-grid')!;

    sortSelect?.addEventListener('change', () => {
      const cards = Array.from(grid.children) as HTMLElement[];

      cards.sort((a, b) => {
        switch (sortSelect.value) {
          case 'stars':
            return (parseInt(b.dataset.stars || '0')) - (parseInt(a.dataset.stars || '0'));
          case 'name':
            return (a.dataset.name || '').localeCompare(b.dataset.name || '');
          case 'recent':
            return (b.dataset.added || '').localeCompare(a.dataset.added || '');
          default: // tier + stars
            const tierDiff = parseInt(a.dataset.tier || '3') - parseInt(b.dataset.tier || '3');
            if (tierDiff !== 0) return tierDiff;
            return (parseInt(b.dataset.stars || '0')) - (parseInt(a.dataset.stars || '0'));
        }
      });

      cards.forEach(card => grid.appendChild(card));
    });
  });
</script>
