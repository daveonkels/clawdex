---
import Layout from '../../layouts/Layout.astro';
import { loadProjects, formatStars } from '../../lib/projects';
import type { Project } from '../../lib/projects';
import { languageLabel, languageColors, statusColors } from '../../lib/constants';
import { makeCanonicalSlug } from '../../lib/compare';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const projects = await loadProjects();
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project, allProjects: projects },
  }));
}

interface Props {
  project: Project;
  allProjects: Project[];
}

const { project, allProjects } = Astro.props;
const { name, slug, tagline, description, language, category, github, status, highlight, emoji, stars, added, github_data, platform, requires_llm, mcp_support, integration_count, perf, ecosystem_role, mentions } = project;

const platformLabels: Record<string, string> = {
  server: 'Server / VPS / Docker',
  browser: 'Browser (PWA / WASM)',
  embedded: 'Embedded / IoT / RPi',
  serverless: 'Serverless (Workers / Lambda)',
  messaging: 'Messaging (Telegram / Discord)',
  desktop: 'Desktop App',
};

const ecosystemRoleLabels: Record<string, string> = {
  reference: 'Reference Implementation',
  fork: 'Fork',
  reimplementation: 'Reimplementation',
  derivative: 'Derivative',
  infrastructure: 'Infrastructure',
  alternative: 'Alternative',
};

const sortedMentions = mentions?.slice().sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).slice(0, 5);

// Load leaderboard to get this project's rank
let leaderboardRank: number | null = null;
let leaderboardTotal: number | null = null;
try {
  const lbPath = path.join(process.cwd(), 'src', 'data', 'generated', 'leaderboard.json');
  const lb = JSON.parse(fs.readFileSync(lbPath, 'utf-8'));
  leaderboardTotal = lb.count;
  const entry = lb.entries.find((e: any) => e.slug === slug);
  if (entry) leaderboardRank = entry.rank;
} catch {}

function daysSince(dateStr: string | null | undefined): number | null {
  if (!dateStr) return null;
  return Math.floor((Date.now() - new Date(dateStr).getTime()) / (24 * 60 * 60 * 1000));
}

function formatCount(n: number): string {
  if (n >= 10000) return `${Math.round(n / 1000)}k`;
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
}

const lang = languageColors[language] || languageColors.multi;

// Other projects for comparison links
const otherProjects = allProjects.filter(p => p.slug !== slug);

// Similar projects: share categories or language, sorted by most categories in common then by stars
const similarProjects = otherProjects
  .map(p => ({
    project: p,
    shared: p.category.filter(c => category.includes(c)).length + (p.language === language ? 1 : 0),
  }))
  .filter(x => x.shared > 0)
  .sort((a, b) => b.shared - a.shared || (b.project.stars ?? 0) - (a.project.stars ?? 0))
  .slice(0, 6)
  .map(x => x.project);

const isDerivative = slug !== 'openclaw';

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": name,
  "description": description,
  "url": `https://shelldex.com/projects/${slug}`,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Linux, macOS, Windows",
  ...(language !== 'multi' ? { "programmingLanguage": languageLabel[language] ?? language } : {}),
  ...(github ? { "codeRepository": `https://github.com/${github}` } : {}),
  ...(isDerivative ? {
    "isBasedOn": {
      "@type": "SoftwareApplication",
      "name": "OpenClaw",
      "url": "https://github.com/openclaw/openclaw"
    }
  } : {}),
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Shelldex", "item": "https://shelldex.com" },
    { "@type": "ListItem", "position": 2, "name": name, "item": `https://shelldex.com/projects/${slug}` },
  ],
};

const formattedDate = added ? new Date(added).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : null;
---

<Layout
  title={`${name} — ${tagline} | Shelldex`}
  description={description}
>
  <script type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-600 mb-10" aria-label="Breadcrumb">
      <a href="/" class="hover:text-biolum transition-colors">Shelldex</a>
      <svg class="w-4 h-4 opacity-40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-400">{name}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-start gap-5 mb-6">
        <span class="text-5xl leading-none mt-1">{emoji}</span>
        <div>
          <h1 class="font-display text-4xl font-bold text-white leading-tight mb-2">{name}</h1>
          <p class="text-lg text-gray-400">{tagline}</p>
        </div>
      </div>

      <!-- Badges -->
      <div class="flex flex-wrap items-center gap-2">
        {language !== 'multi' && (
          <span class={`badge-language border ${lang.bg} ${lang.text} ${lang.border}`}>
            {languageLabel[language] ?? language}
          </span>
        )}
        <span class={`badge-language border ${statusColors[status]}`}>
          {status}
        </span>
        {stars !== undefined && stars > 0 && github && (
          <a
            href={`https://github.com/${github}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 badge-language border border-yellow-500/20 bg-yellow-500/10 text-yellow-400 hover:bg-yellow-500/20 transition-colors"
          >
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.896l-7.416 3.517 1.48-8.279L0 9.306l8.332-1.151z"/></svg>
            {formatStars(stars)}
          </a>
        )}
        {category.map((cat: string) => (
          <span class="badge-language border border-white/10 bg-white/5 text-gray-500">{cat}</span>
        ))}
      </div>
    </header>

    <!-- Description -->
    <section class="mb-8">
      <h2 class="font-display text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">About</h2>
      <p class="text-gray-300 leading-relaxed text-lg">{description}</p>
    </section>

    <!-- At a Glance -->
    {(platform || requires_llm !== undefined || mcp_support !== undefined || integration_count || ecosystem_role || perf) && (
      <section class="mb-8">
        <h2 class="font-display text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">At a Glance</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {platform && platform.length > 0 && (
            <div class="rounded-lg border border-white/5 bg-ocean-card px-4 py-3">
              <p class="text-xs text-gray-500 mb-1.5">Runs On</p>
              <div class="flex flex-wrap gap-1">
                {platform.map((p: string) => (
                  <span class="text-xs text-gray-300 bg-white/[0.06] rounded px-1.5 py-0.5">{platformLabels[p] ?? p}</span>
                ))}
              </div>
            </div>
          )}
          {requires_llm !== undefined && (
            <div class="rounded-lg border border-white/5 bg-ocean-card px-4 py-3">
              <p class="text-xs text-gray-500 mb-1.5">LLM Required</p>
              <p class={`text-sm font-medium ${requires_llm ? 'text-gray-300' : 'text-green-400'}`}>
                {requires_llm ? 'Yes — needs API key' : 'No — zero LLM cost'}
              </p>
            </div>
          )}
          {mcp_support !== undefined && (
            <div class="rounded-lg border border-white/5 bg-ocean-card px-4 py-3">
              <p class="text-xs text-gray-500 mb-1.5">MCP Support</p>
              <p class={`text-sm font-medium ${mcp_support ? 'text-purple-400' : 'text-gray-500'}`}>
                {mcp_support ? 'Yes' : 'No'}
              </p>
            </div>
          )}
          {integration_count && (
            <div class="rounded-lg border border-white/5 bg-ocean-card px-4 py-3">
              <p class="text-xs text-gray-500 mb-1.5">Integrations</p>
              <p class="text-lg font-mono text-gray-300">{integration_count}+</p>
            </div>
          )}
          {ecosystem_role && (
            <div class="rounded-lg border border-white/5 bg-ocean-card px-4 py-3">
              <p class="text-xs text-gray-500 mb-1.5">Ecosystem Role</p>
              <p class="text-sm font-medium text-gray-300">{ecosystemRoleLabels[ecosystem_role] ?? ecosystem_role}</p>
            </div>
          )}
          {perf && (
            <div class="rounded-lg border border-white/5 bg-ocean-card px-4 py-3">
              <p class="text-xs text-gray-500 mb-1.5">Performance</p>
              <div class="space-y-0.5">
                {perf.binary_size && <p class="text-xs text-gray-300"><span class="text-gray-500">Binary:</span> {perf.binary_size}</p>}
                {perf.startup_time && <p class="text-xs text-gray-300"><span class="text-gray-500">Startup:</span> {perf.startup_time}</p>}
                {perf.ram && <p class="text-xs text-gray-300"><span class="text-gray-500">RAM:</span> {perf.ram}</p>}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Highlight -->
    <section class="mb-8 rounded-xl bg-biolum/5 border border-biolum/15 px-6 py-5">
      <p class="text-biolum font-medium leading-relaxed">{highlight}</p>
    </section>

    <!-- GitHub Stats -->
    {github_data && (
      <section class="mb-8">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-display text-sm font-semibold text-gray-500 uppercase tracking-wider">GitHub Stats</h2>
          {leaderboardRank && (
            <a href="/leaderboard" class="text-sm text-gray-500 hover:text-biolum transition-colors">
              #{leaderboardRank} of {leaderboardTotal} on the leaderboard →
            </a>
          )}
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="rounded-lg border border-white/5 bg-ocean-card px-4 py-3">
            <p class="text-xs text-gray-500 mb-1">Stars</p>
            <p class="text-lg font-mono text-yellow-300">★ {formatCount(github_data.stars)}</p>
            {github_data.star_growth_7d !== null && github_data.star_growth_7d !== 0 && (
              <p class={`text-xs font-mono mt-0.5 ${github_data.star_growth_7d > 0 ? 'text-biolum' : 'text-red-400'}`}>
                {github_data.star_growth_7d > 0 ? '+' : ''}{formatCount(github_data.star_growth_7d)} this week
              </p>
            )}
          </div>
          <div class="rounded-lg border border-white/5 bg-ocean-card px-4 py-3">
            <p class="text-xs text-gray-500 mb-1">Forks</p>
            <p class="text-lg font-mono text-gray-300">{formatCount(github_data.forks)}</p>
          </div>
          <div class="rounded-lg border border-white/5 bg-ocean-card px-4 py-3">
            <p class="text-xs text-gray-500 mb-1">Open Issues</p>
            <p class="text-lg font-mono text-gray-300">{formatCount(github_data.open_issues)}</p>
          </div>
          <div class="rounded-lg border border-white/5 bg-ocean-card px-4 py-3">
            <p class="text-xs text-gray-500 mb-1">Last Commit</p>
            <p class={`text-lg font-mono ${(daysSince(github_data.last_commit) ?? 999) <= 7 ? 'text-biolum' : (daysSince(github_data.last_commit) ?? 999) <= 30 ? 'text-gray-300' : 'text-gray-600'}`}>
              {daysSince(github_data.last_commit) !== null ? `${daysSince(github_data.last_commit)}d ago` : '—'}
            </p>
          </div>
        </div>
        <div class="flex flex-wrap gap-x-6 gap-y-1 mt-3 text-xs text-gray-500">
          {github_data.license && (
            <span>License: <span class="text-gray-400">{github_data.license}</span></span>
          )}
          {github_data.latest_release && (
            <span>Latest release: <span class="text-gray-400 font-mono">{github_data.latest_release}</span></span>
          )}
        </div>
      </section>
    )}

    <!-- What People Are Saying -->
    {sortedMentions && sortedMentions.length > 0 && (
      <section class="mb-8">
        <h2 class="font-display text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">What People Are Saying</h2>
        <div class="space-y-3">
          {sortedMentions.map((m) => (
            <a
              href={m.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-start gap-3 rounded-xl border border-white/5 bg-ocean-card/50 px-5 py-4 hover:border-biolum/20 transition-all group"
            >
              <span class="flex-shrink-0 mt-0.5 text-gray-500 group-hover:text-biolum transition-colors">
                {m.type === 'tweet' && (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                )}
                {m.type === 'article' && (
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
                )}
                {m.type === 'video' && (
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                )}
                {m.type === 'post' && (
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
                )}
              </span>
              <div class="flex-1 min-w-0">
                {m.quote && (
                  <p class="text-sm text-gray-300 leading-relaxed mb-1.5 italic">"{m.quote}"</p>
                )}
                {!m.quote && m.title && (
                  <p class="text-sm text-gray-300 leading-relaxed mb-1.5">{m.title}</p>
                )}
                <div class="flex items-center gap-2 text-xs text-gray-500">
                  <span class="font-medium text-gray-400">{m.author}</span>
                  {m.source && <span>on {m.source}</span>}
                  <span>{new Date(m.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                </div>
              </div>
              {m.thumbnail && (
                <img src={m.thumbnail} alt="" class="w-16 h-12 rounded object-cover flex-shrink-0" loading="lazy" />
              )}
              <svg class="w-4 h-4 text-gray-600 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Relation to OpenClaw -->
    {isDerivative && (
      <section class="mb-8">
        <h2 class="font-display text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">OpenClaw Relationship</h2>
        <p class="text-gray-400 leading-relaxed">
          {name} is an <a href="/projects/openclaw" class="text-biolum hover:underline">OpenClaw</a>-inspired project — part of the growing ecosystem of personal AI agent frameworks that trace their lineage to Peter Steinberger's original self-hosted assistant.
        </p>
      </section>
    )}

    <!-- GitHub CTA -->
    {github && (
      <div class="mb-10">
        <a
          href={`https://github.com/${github}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-6 py-3 bg-white/5 border border-white/10 rounded-lg text-gray-300 hover:border-biolum/40 hover:text-biolum transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span class="font-medium">{github}</span>
          <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
        {formattedDate && (
          <p class="text-xs text-gray-600 mt-3">Added to Shelldex on {formattedDate}</p>
        )}
      </div>
    )}

    <!-- Compare with... -->
    <section class="mb-8">
      <h2 class="font-display text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Compare with...</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
        {otherProjects.map(p => (
          <a
            href={`/compare/${makeCanonicalSlug(slug, p.slug)}`}
            class="flex items-center gap-2 rounded-lg border border-white/5 bg-ocean-card/50 px-3 py-2 text-sm text-gray-400 hover:text-biolum hover:border-biolum/20 transition-all"
          >
            <span class="flex-shrink-0">{p.emoji}</span>
            <span class="truncate">{p.name}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Similar Projects -->
    {similarProjects.length > 0 && (
      <section class="mb-8">
        <h2 class="font-display text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Similar Projects</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {similarProjects.map(p => (
            <a
              href={`/projects/${p.slug}`}
              class="flex items-center gap-3 rounded-lg border border-white/5 bg-ocean-card/50 px-4 py-3 hover:border-biolum/20 transition-all group"
            >
              <span class="text-xl flex-shrink-0">{p.emoji}</span>
              <div class="min-w-0">
                <p class="text-white text-sm font-medium group-hover:text-biolum transition-colors truncate">{p.name}</p>
                <p class="text-xs text-gray-500 truncate">{p.tagline}</p>
              </div>
              {p.stars !== undefined && p.stars > 0 && (
                <span class="text-xs text-yellow-500/70 font-mono ml-auto flex-shrink-0">★ {formatStars(p.stars)}</span>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Community -->
    <section class="mb-10">
      <h2 class="font-display text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Community</h2>
      <a
        href={`https://www.reddit.com/search/?q=${encodeURIComponent(name)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-biolum transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
        Search Reddit for {name}
        <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
    </section>

    <!-- Back link -->
    <div class="border-t border-white/5 pt-8 flex flex-wrap gap-6">
