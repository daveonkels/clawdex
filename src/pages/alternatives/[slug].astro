---
import Layout from '../../layouts/Layout.astro';
import { loadProjects, formatStars } from '../../lib/projects';
import { loadLeaderboard, computeHealthScore } from '../../lib/compare';
import { buildComparisonHref, getIndexableCompareSlugSet } from '../../lib/compare-seo.js';
import { languageLabel, languageColors } from '../../lib/constants';
import type { Project } from '../../lib/projects';

export async function getStaticPaths() {
  const projects = await loadProjects();
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project, allProjects: projects },
  }));
}

interface Props {
  project: Project;
  allProjects: Project[];
}

const { project, allProjects } = Astro.props;
const { name, slug, language, category, emoji, stars } = project;
const year = new Date().getFullYear();
const { entries: leaderboard } = loadLeaderboard();

const langName = languageLabel[language] ?? language;

// All other projects, scored by similarity then sorted by stars
const alternatives = allProjects
  .filter(p => p.slug !== slug)
  .map(p => ({
    project: p,
    shared: p.category.filter(c => category.includes(c)).length + (p.language === language ? 1 : 0),
  }))
  .sort((a, b) => b.shared - a.shared || (b.project.stars ?? 0) - (a.project.stars ?? 0));

const topAlternatives = alternatives.filter(a => a.shared > 0);
const otherProjects = alternatives.filter(a => a.shared === 0);
const indexableCompareSlugs = getIndexableCompareSlugSet(allProjects);

function getHealthScore(s: string): number {
  const entry = leaderboard.find(e => e.slug === s);
  return computeHealthScore(entry ?? null);
}

const pageTitle = `${name} Alternatives: ${alternatives.length} Similar AI Agents Compared (${year}) | Shelldex`;
const pageDescription = `Looking for alternatives to ${name}? Compare ${alternatives.length} similar open-source AI agent projects by GitHub stars, language, and features.`;

// FAQ schema
const topNames = topAlternatives.slice(0, 5).map(a => a.project.name);
const faqItems = [
  {
    question: `What are the best alternatives to ${name}?`,
    answer: topNames.length > 0
      ? `The most similar alternatives to ${name} are ${topNames.join(', ')}. These projects share categories or programming language (${langName}) with ${name}. See the full ranked list on Shelldex.`
      : `Shelldex tracks ${alternatives.length} projects in the OpenClaw ecosystem that serve as alternatives to ${name}.`,
  },
  {
    question: `Is ${name} better than its alternatives?`,
    answer: `${name} has ${formatStars(stars ?? 0)} GitHub stars and is written in ${langName}. Whether it's "better" depends on your priorities — language preference, performance requirements, security model, and deployment platform all matter. Compare projects side by side on Shelldex.`,
  },
  {
    question: `How many alternatives to ${name} exist?`,
    answer: `Shelldex currently tracks ${alternatives.length} alternative projects to ${name} in the OpenClaw ecosystem. ${topAlternatives.length} of these share categories or programming language with ${name}.`,
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer },
  })),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Shelldex", "item": "https://shelldex.com" },
    { "@type": "ListItem", "position": 2, "name": name, "item": `https://shelldex.com/projects/${slug}/` },
    { "@type": "ListItem", "position": 3, "name": "Alternatives", "item": `https://shelldex.com/alternatives/${slug}/` },
  ],
};
---

<Layout title={pageTitle} description={pageDescription} robots="noindex, follow">
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-600 mb-10" aria-label="Breadcrumb">
      <a href="/" class="hover:text-biolum transition-colors">Shelldex</a>
      <svg class="w-4 h-4 opacity-40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <a href={`/projects/${slug}/`} class="hover:text-biolum transition-colors">{name}</a>
      <svg class="w-4 h-4 opacity-40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-400">Alternatives</span>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white leading-tight mb-4">
        {emoji} {name} Alternatives ({year})
      </h1>
      <p class="text-lg text-gray-400 leading-relaxed">
        {alternatives.length} open-source alternatives to <a href={`/projects/${slug}/`} class="text-biolum hover:text-biolum-light transition-colors">{name}</a>
        ({formatStars(stars ?? 0)} stars, {langName}) in the OpenClaw ecosystem.
        {topAlternatives.length > 0 && ` ${topAlternatives.length} share categories or language.`}
      </p>
    </header>

    <!-- Most Similar -->
    {topAlternatives.length > 0 && (
      <section class="mb-12">
        <h2 class="font-display text-2xl font-bold text-white mb-6">Most Similar to {name}</h2>
        <div class="space-y-4">
          {topAlternatives.slice(0, 12).map(({ project: p }) => {
            const lang = languageColors[p.language] || languageColors.multi;
            const pLangName = languageLabel[p.language] ?? p.language;
            const health = getHealthScore(p.slug);

            return (
              <article class="rounded-xl border border-white/5 bg-ocean-card p-5 hover:border-biolum/20 transition-all">
                <div class="flex items-start gap-4">
                  <span class="text-2xl leading-none mt-0.5 flex-shrink-0">{p.emoji}</span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-3 mb-1 flex-wrap">
                      <a href={`/projects/${p.slug}/`} class="font-display text-lg font-bold text-white hover:text-biolum transition-colors">{p.name}</a>
                      {p.stars && p.stars > 0 && (
                        <span class="text-yellow-400 text-sm font-mono">{formatStars(p.stars)} stars</span>
                      )}
                      <span class={`text-xs px-1.5 py-0.5 rounded border ${lang.bg} ${lang.text} ${lang.border}`}>{pLangName}</span>
                      {health >= 70 && <span class="text-xs text-biolum">Healthy</span>}
                    </div>
                    <p class="text-sm text-gray-400 mb-3">{p.tagline}</p>
                    <div class="flex flex-wrap gap-3">
                      <a href={buildComparisonHref(slug, p.slug, indexableCompareSlugs)} class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-biolum transition-colors">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                        Compare with {name}
                      </a>
                      <a href={`/projects/${p.slug}/`} class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-biolum transition-colors">
                        Full profile
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                      </a>
                      <a href={`/alternatives/${p.slug}/`} class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-biolum transition-colors">
                        {p.name} alternatives
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                      </a>
                    </div>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )}

    <!-- Other Projects -->
    {otherProjects.length > 0 && (
      <section class="mb-12">
        <h2 class="font-display text-2xl font-bold text-white mb-6">Other Projects in the Ecosystem</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {otherProjects.slice(0, 16).map(({ project: p }) => {
            return (
              <a
                href={`/projects/${p.slug}/`}
                class="flex items-center gap-3 rounded-lg border border-white/5 bg-ocean-card/50 px-4 py-3 hover:border-biolum/20 transition-all group"
              >
                <span class="text-xl flex-shrink-0">{p.emoji}</span>
                <div class="min-w-0 flex-1">
                  <p class="text-white text-sm font-medium group-hover:text-biolum transition-colors truncate">{p.name}</p>
                  <p class="text-xs text-gray-500 truncate">{p.tagline}</p>
                </div>
                {p.stars && p.stars > 0 && (
                  <span class="text-xs text-yellow-500/70 font-mono flex-shrink-0">{formatStars(p.stars)}</span>
                )}
              </a>
            );
          })}
        </div>
        <a href={`/compare/?a=${slug}`} class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-biolum transition-colors mt-4">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
          Compare {name} with any project in the compare tool
        </a>
      </section>
    )}

    <!-- FAQ -->
    <section class="mb-12">
      <h2 class="font-display text-2xl font-bold text-white mb-6">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="group rounded-xl border border-white/5 bg-ocean-card">
            <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-white font-medium text-sm hover:text-biolum transition-colors">
              <span>{item.question}</span>
              <svg class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-4 text-sm text-gray-400 leading-relaxed border-t border-white/5 pt-3">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Back links -->
    <div class="border-t border-white/5 pt-8 flex flex-wrap gap-6">
      <a href={`/projects/${slug}/`} class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-biolum transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 5l-7 7 7 7"/></svg>
        {name} profile
      </a>
      <a href="/best-alternatives/" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-biolum transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 5l-7 7 7 7"/></svg>
        All OpenClaw alternatives
      </a>
      <a href="/compare/" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-biolum transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
        Compare projects
      </a>
      <a href="/" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-biolum transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Directory
      </a>
    </div>
  </div>
</Layout>
