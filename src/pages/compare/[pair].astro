---
import Layout from '../../layouts/Layout.astro';
import { loadProjects, formatStars } from '../../lib/projects';
import { languageLabel, languageColors, statusColors } from '../../lib/constants';
import {
  generateAllPairs,
  makeCanonicalSlug,
  getUniquePairs,
  generateKeyDifferences,
  generateRecommendation,
  getRelatedComparisons,
  computeHealthScore,
  loadLeaderboard,
} from '../../lib/compare';
import type { PairEntry, LeaderboardEntry } from '../../lib/compare';
import type { Project } from '../../lib/projects';

export async function getStaticPaths() {
  const projects = await loadProjects();
  const allPairs = generateAllPairs(projects);
  const projectMap = new Map(projects.map(p => [p.slug, p]));
  const lb = loadLeaderboard();
  const lbMap = new Map(lb.entries.map(e => [e.slug, e]));
  const uniquePairs = getUniquePairs(projects);

  return allPairs.map(entry => {
    const a = projectMap.get(entry.slugA)!;
    const b = projectMap.get(entry.slugB)!;
    const isCanonical = entry.pair === entry.canonical;
    const aEntry = lbMap.get(entry.slugA) ?? null;
    const bEntry = lbMap.get(entry.slugB) ?? null;

    return {
      params: { pair: entry.pair },
      props: {
        a,
        b,
        aEntry,
        bEntry,
        isCanonical,
        canonicalUrl: `https://shelldex.com/compare/${entry.canonical}`,
        keyDifferences: generateKeyDifferences(a, b, aEntry, bEntry),
        recommendation: generateRecommendation(a, b, aEntry, bEntry),
        related: getRelatedComparisons(entry.slugA, entry.slugB, uniquePairs),
      },
    };
  });
}

interface Props {
  a: Project;
  b: Project;
  aEntry: LeaderboardEntry | null;
  bEntry: LeaderboardEntry | null;
  isCanonical: boolean;
  canonicalUrl: string;
  keyDifferences: string[];
  recommendation: string;
  related: PairEntry[];
}

const { a, b, aEntry, bEntry, isCanonical, canonicalUrl, keyDifferences, recommendation, related } = Astro.props;

function daysSince(dateStr: string | null | undefined): number | null {
  if (!dateStr) return null;
  return Math.floor((Date.now() - new Date(dateStr).getTime()) / (24 * 60 * 60 * 1000));
}

function formatCount(n: number | null | undefined): string {
  if (n === null || n === undefined) return '—';
  if (n >= 10000) return `${Math.round(n / 1000)}k`;
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
}

function freshness(days: number | null): string {
  if (days === null) return 'text-gray-600';
  if (days <= 7) return 'text-biolum';
  if (days <= 30) return 'text-gray-300';
  return 'text-gray-600';
}

const aStars = a.github_data?.stars ?? a.stars ?? 0;
const bStars = b.github_data?.stars ?? b.stars ?? 0;
const aHealthScore = computeHealthScore(aEntry);
const bHealthScore = computeHealthScore(bEntry);
const aRank = aEntry?.rank ?? null;
const bRank = bEntry?.rank ?? null;
const lb = loadLeaderboard();
const lbTotal = lb.count;

const aLang = languageColors[a.language] || languageColors.multi;
const bLang = languageColors[b.language] || languageColors.multi;

const pageTitle = `${a.name} vs ${b.name} — Shelldex`;
const pageDescription = `Compare ${a.name} and ${b.name}: side-by-side GitHub stats, stars, growth, language, and project health. Find which OpenClaw alternative fits your needs.`;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Shelldex", "item": "https://shelldex.com" },
    { "@type": "ListItem", "position": 2, "name": "Compare", "item": "https://shelldex.com/compare" },
    { "@type": "ListItem", "position": 3, "name": `${a.name} vs ${b.name}`, "item": canonicalUrl },
  ],
};

const webPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": canonicalUrl,
  "about": [
    {
      "@type": "SoftwareApplication",
      "name": a.name,
      "url": `https://shelldex.com/projects/${a.slug}`,
      ...(a.github ? { "codeRepository": `https://github.com/${a.github}` } : {}),
    },
    {
      "@type": "SoftwareApplication",
      "name": b.name,
      "url": `https://shelldex.com/projects/${b.slug}`,
      ...(b.github ? { "codeRepository": `https://github.com/${b.github}` } : {}),
    },
  ],
};

// Metrics rows for the comparison table
const metrics = [
  {
    label: 'Stars',
    aVal: aStars > 0 ? `★ ${formatCount(aStars)}` : '—',
    bVal: bStars > 0 ? `★ ${formatCount(bStars)}` : '—',
    aClass: 'text-yellow-300 font-mono',
    bClass: 'text-yellow-300 font-mono',
    aWins: aStars > bStars,
    bWins: bStars > aStars,
  },
  {
    label: '7d Growth',
    aVal: a.github_data?.star_growth_7d !== null && a.github_data?.star_growth_7d !== undefined
      ? (a.github_data.star_growth_7d > 0 ? `+${formatCount(a.github_data.star_growth_7d)}` : String(a.github_data.star_growth_7d))
      : '—',
    bVal: b.github_data?.star_growth_7d !== null && b.github_data?.star_growth_7d !== undefined
      ? (b.github_data.star_growth_7d > 0 ? `+${formatCount(b.github_data.star_growth_7d)}` : String(b.github_data.star_growth_7d))
      : '—',
    aClass: (a.github_data?.star_growth_7d ?? 0) > 0 ? 'text-biolum font-mono' : 'text-gray-500 font-mono',
    bClass: (b.github_data?.star_growth_7d ?? 0) > 0 ? 'text-biolum font-mono' : 'text-gray-500 font-mono',
    aWins: (a.github_data?.star_growth_7d ?? 0) > (b.github_data?.star_growth_7d ?? 0),
    bWins: (b.github_data?.star_growth_7d ?? 0) > (a.github_data?.star_growth_7d ?? 0),
  },
  {
    label: 'Forks',
    aVal: formatCount(a.github_data?.forks),
    bVal: formatCount(b.github_data?.forks),
    aClass: 'text-gray-300 font-mono',
    bClass: 'text-gray-300 font-mono',
    aWins: (a.github_data?.forks ?? 0) > (b.github_data?.forks ?? 0),
    bWins: (b.github_data?.forks ?? 0) > (a.github_data?.forks ?? 0),
  },
  {
    label: 'Open Issues',
    aVal: formatCount(a.github_data?.open_issues),
    bVal: formatCount(b.github_data?.open_issues),
    aClass: 'text-gray-300 font-mono',
    bClass: 'text-gray-300 font-mono',
    aWins: (a.github_data?.open_issues ?? Infinity) < (b.github_data?.open_issues ?? Infinity),
    bWins: (b.github_data?.open_issues ?? Infinity) < (a.github_data?.open_issues ?? Infinity),
  },
  {
    label: 'Language',
    aVal: languageLabel[a.language] ?? a.language,
    bVal: languageLabel[b.language] ?? b.language,
    aClass: `${aLang.text}`,
    bClass: `${bLang.text}`,
    aWins: false,
    bWins: false,
  },
  {
    label: 'Categories',
    aVal: a.category.join(', '),
    bVal: b.category.join(', '),
    aClass: 'text-gray-400 text-sm',
    bClass: 'text-gray-400 text-sm',
    aWins: false,
    bWins: false,
  },
  {
    label: 'Platform',
    aVal: a.platform?.map(p => p.charAt(0).toUpperCase() + p.slice(1)).join(', ') ?? '—',
    bVal: b.platform?.map(p => p.charAt(0).toUpperCase() + p.slice(1)).join(', ') ?? '—',
    aClass: 'text-gray-400 text-sm',
    bClass: 'text-gray-400 text-sm',
    aWins: false,
    bWins: false,
  },
  {
    label: 'LLM Required',
    aVal: a.requires_llm === undefined ? '—' : a.requires_llm ? 'Yes' : 'No',
    bVal: b.requires_llm === undefined ? '—' : b.requires_llm ? 'Yes' : 'No',
    aClass: a.requires_llm === false ? 'text-green-400' : 'text-gray-300',
    bClass: b.requires_llm === false ? 'text-green-400' : 'text-gray-300',
    aWins: a.requires_llm === false && b.requires_llm !== false,
    bWins: b.requires_llm === false && a.requires_llm !== false,
  },
  {
    label: 'MCP Support',
    aVal: a.mcp_support === undefined ? '—' : a.mcp_support ? 'Yes' : 'No',
    bVal: b.mcp_support === undefined ? '—' : b.mcp_support ? 'Yes' : 'No',
    aClass: a.mcp_support ? 'text-purple-400' : 'text-gray-500',
    bClass: b.mcp_support ? 'text-purple-400' : 'text-gray-500',
    aWins: a.mcp_support === true && !b.mcp_support,
    bWins: b.mcp_support === true && !a.mcp_support,
  },
  {
    label: 'Integrations',
    aVal: a.integration_count ? `${a.integration_count}+` : '—',
    bVal: b.integration_count ? `${b.integration_count}+` : '—',
    aClass: 'text-gray-300 font-mono',
    bClass: 'text-gray-300 font-mono',
    aWins: (a.integration_count ?? 0) > (b.integration_count ?? 0),
    bWins: (b.integration_count ?? 0) > (a.integration_count ?? 0),
  },
  {
    label: 'License',
    aVal: a.github_data?.license ?? '—',
    bVal: b.github_data?.license ?? '—',
    aClass: 'text-gray-300',
    bClass: 'text-gray-300',
    aWins: false,
    bWins: false,
  },
  {
    label: 'Last Commit',
    aVal: daysSince(a.github_data?.last_commit) !== null ? `${daysSince(a.github_data?.last_commit)}d ago` : '—',
    bVal: daysSince(b.github_data?.last_commit) !== null ? `${daysSince(b.github_data?.last_commit)}d ago` : '—',
    aClass: freshness(daysSince(a.github_data?.last_commit)),
    bClass: freshness(daysSince(b.github_data?.last_commit)),
    aWins: (daysSince(a.github_data?.last_commit) ?? Infinity) < (daysSince(b.github_data?.last_commit) ?? Infinity),
    bWins: (daysSince(b.github_data?.last_commit) ?? Infinity) < (daysSince(a.github_data?.last_commit) ?? Infinity),
  },
  {
    label: 'Latest Release',
    aVal: a.github_data?.latest_release ?? '—',
    bVal: b.github_data?.latest_release ?? '—',
    aClass: 'text-gray-300 font-mono text-sm',
    bClass: 'text-gray-300 font-mono text-sm',
    aWins: false,
    bWins: false,
  },
  {
    label: 'Health Score',
    aVal: `${aHealthScore}/100`,
    bVal: `${bHealthScore}/100`,
    aClass: aHealthScore >= 70 ? 'text-biolum font-mono' : aHealthScore >= 40 ? 'text-yellow-400 font-mono' : 'text-coral font-mono',
    bClass: bHealthScore >= 70 ? 'text-biolum font-mono' : bHealthScore >= 40 ? 'text-yellow-400 font-mono' : 'text-coral font-mono',
    aWins: aHealthScore > bHealthScore,
    bWins: bHealthScore > aHealthScore,
  },
  {
    label: 'Leaderboard Rank',
    aVal: aRank ? `#${aRank} of ${lbTotal}` : '—',
    bVal: bRank ? `#${bRank} of ${lbTotal}` : '—',
    aClass: 'text-gray-300 font-mono',
    bClass: 'text-gray-300 font-mono',
    aWins: aRank !== null && bRank !== null && aRank < bRank,
    bWins: bRank !== null && aRank !== null && bRank < aRank,
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={isCanonical ? undefined : canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(webPageJsonLd)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-600 mb-10" aria-label="Breadcrumb">
      <a href="/" class="hover:text-biolum transition-colors">Shelldex</a>
      <svg class="w-4 h-4 opacity-40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <a href="/compare" class="hover:text-biolum transition-colors">Compare</a>
      <svg class="w-4 h-4 opacity-40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-400">{a.name} vs {b.name}</span>
    </nav>

    <!-- H1 -->
    <header class="text-center mb-12">
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white leading-tight">
        <span class="text-4xl sm:text-5xl">{a.emoji}</span>
        {a.name}
        <span class="text-gray-500 mx-2">vs</span>
        {b.name}
        <span class="text-4xl sm:text-5xl">{b.emoji}</span>
      </h1>
      <p class="text-gray-400 mt-4 max-w-2xl mx-auto">
        Side-by-side comparison of {a.name} and {b.name} — two projects in the OpenClaw ecosystem.
      </p>
    </header>

    <!-- Side-by-side metrics table -->
    <section class="mb-12">
      <div class="rounded-xl border border-white/5 bg-ocean-card overflow-hidden">
        <!-- Table header -->
        <div class="grid grid-cols-3 border-b border-white/10 text-sm">
          <div class="px-4 py-3 text-gray-500 font-medium">Metric</div>
          <div class="px-4 py-3 text-center">
            <a href={`/projects/${a.slug}`} class="text-white font-semibold hover:text-biolum transition-colors">
              {a.emoji} {a.name}
            </a>
          </div>
          <div class="px-4 py-3 text-center">
            <a href={`/projects/${b.slug}`} class="text-white font-semibold hover:text-biolum transition-colors">
              {b.emoji} {b.name}
            </a>
          </div>
        </div>

        <!-- Metric rows -->
        {metrics.map((m, i) => (
          <div class={`grid grid-cols-3 ${i < metrics.length - 1 ? 'border-b border-white/5' : ''} text-sm`}>
            <div class="px-4 py-3 text-gray-500">{m.label}</div>
            <div class={`px-4 py-3 text-center ${m.aClass} ${m.aWins ? 'bg-biolum/5' : ''}`}>
              {m.aVal}
            </div>
            <div class={`px-4 py-3 text-center ${m.bClass} ${m.bWins ? 'bg-biolum/5' : ''}`}>
              {m.bVal}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Key Differences -->
    {keyDifferences.length > 0 && (
      <section class="mb-12">
        <h2 class="font-display text-2xl font-bold text-white mb-6">Key Differences</h2>
        <ul class="space-y-4">
          {keyDifferences.map(diff => (
            <li class="flex items-start gap-3 text-gray-300 leading-relaxed">
              <span class="text-biolum mt-1 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </span>
              <span>{diff}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Which should you choose? -->
    <section class="mb-12">
      <h2 class="font-display text-2xl font-bold text-white mb-6">Which should you choose?</h2>
      <div class="space-y-4 text-gray-300 leading-relaxed">
        {recommendation.split('\n\n').map(para => (
          <p>{para}</p>
        ))}
      </div>
    </section>

    <!-- Project links (CTAs) -->
    <section class="mb-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a
          href={`/projects/${a.slug}`}
          class="flex items-center gap-4 rounded-xl border border-white/5 bg-ocean-card p-5 hover:border-biolum/30 transition-all group"
        >
          <span class="text-3xl">{a.emoji}</span>
          <div>
            <p class="text-white font-semibold group-hover:text-biolum transition-colors">{a.name}</p>
            <p class="text-sm text-gray-500">{a.tagline}</p>
          </div>
          <svg class="w-5 h-5 text-gray-600 ml-auto group-hover:text-biolum transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
        <a
          href={`/projects/${b.slug}`}
          class="flex items-center gap-4 rounded-xl border border-white/5 bg-ocean-card p-5 hover:border-biolum/30 transition-all group"
        >
          <span class="text-3xl">{b.emoji}</span>
          <div>
            <p class="text-white font-semibold group-hover:text-biolum transition-colors">{b.name}</p>
            <p class="text-sm text-gray-500">{b.tagline}</p>
          </div>
          <svg class="w-5 h-5 text-gray-600 ml-auto group-hover:text-biolum transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- Related Comparisons -->
    {related.length > 0 && (
      <section class="mb-12">
        <h2 class="font-display text-2xl font-bold text-white mb-6">Related Comparisons</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {related.map(r => (
            <a
              href={`/compare/${r.canonical}`}
              class="flex items-center gap-2 rounded-lg border border-white/5 bg-ocean-card/50 px-4 py-3 text-sm text-gray-400 hover:text-biolum hover:border-biolum/20 transition-all"
            >
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
              <span>{r.slugA.replace(/-/g, ' ')} vs {r.slugB.replace(/-/g, ' ')}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Back links -->
    <div class="border-t border-white/5 pt-8 flex flex-wrap gap-6">
      <a href="/compare" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-biolum transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 5l-7 7 7 7"/></svg>
        All comparisons
      </a>
      <a href="/" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-biolum transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Directory
      </a>
    </div>

  </div>
</Layout>
