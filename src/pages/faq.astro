---
import Layout from '../layouts/Layout.astro';
import { loadProjects, formatStars } from '../lib/projects';
import { loadLeaderboard } from '../lib/compare';

const projects = await loadProjects();
const { entries: leaderboard } = loadLeaderboard();
const projectCount = projects.length;

// Language counts
const langCounts = new Map<string, number>();
for (const p of projects) {
  langCounts.set(p.language, (langCounts.get(p.language) || 0) + 1);
}
const langCount = langCounts.size;

// Helper to look up formatted star count by slug
function stars(slug: string): string {
  const entry = leaderboard.find(e => e.slug === slug);
  if (entry) return formatStars(entry.stars);
  const proj = projects.find(p => p.slug === slug);
  return formatStars(proj?.github_data?.stars ?? proj?.stars ?? 0);
}

// Helper for full number star count
function starsNum(slug: string): string {
  const entry = leaderboard.find(e => e.slug === slug);
  if (entry) return entry.stars.toLocaleString();
  const proj = projects.find(p => p.slug === slug);
  return (proj?.github_data?.stars ?? proj?.stars ?? 0).toLocaleString();
}

// Top 5 projects by stars (excluding openclaw)
const top5 = leaderboard.filter(e => e.slug !== 'openclaw').slice(0, 5);

// Rust projects
const rustProjects = projects.filter(p => p.language.toLowerCase() === 'rust');

// Most starred alternative
const topAlt = leaderboard.find(e => e.slug !== 'openclaw');

// FAQ schema data — plain text versions of Q&A for JSON-LD
const faqSchemaItems = [
  { q: "What is OpenClaw?", a: `OpenClaw is a self-hosted, open-source personal AI super-agent platform created by Peter Steinberger. Written in TypeScript under the MIT license, it has accumulated over ${starsNum('openclaw')} GitHub stars. It gives you a personal AI agent that interacts with your tools, files, and services on your behalf, running on your own hardware.` },
  { q: "What are the best OpenClaw alternatives?", a: `The top alternatives by GitHub stars are Nanobot (${stars('nanobot')}), ZeroClaw (${stars('zeroclaw')}), PicoClaw (${stars('picoclaw')}), and AstrBot (${stars('astrbot')}). For security, consider NanoClaw, IronClaw, or Moltis. For cloud-native, Moltworker runs on Cloudflare Workers.` },
  { q: "How many OpenClaw alternatives exist?", a: `Shelldex currently tracks ${projectCount} projects across the OpenClaw ecosystem, including the original, direct forks, clean-room reimplementations, and inspired projects. The ecosystem is still growing rapidly.` },
  { q: "What is the OpenClaw ecosystem?", a: `The OpenClaw ecosystem refers to the constellation of projects that have emerged around the original OpenClaw personal AI agent. It includes forks, language ports, security-hardened variants, minimal reimplementations, and cloud-hosted versions spanning ${langCount} programming languages.` },
  { q: "Is OpenClaw free and open source?", a: "Yes. OpenClaw is released under the MIT license. You can use, modify, and redistribute it freely, including in commercial products. Most ecosystem projects also use permissive licenses like MIT or Apache 2.0." },
  { q: "What is the lightest OpenClaw alternative?", a: "ZeroClaw ships as a 3.4MB Rust binary with sub-10ms startup and under 5MB RAM. PicoClaw runs on $10 RISC-V boards with under 10MB RAM. BashoBot is built entirely in Bash with zero runtime dependencies." },
  { q: "Can you run an OpenClaw alternative on a Raspberry Pi?", a: "Yes. PicoClaw, ZeroClaw, BashoBot, MicroClaw, and IronClaw all run well on Raspberry Pi. The main bottleneck is LLM inference, not the agent framework itself." },
  { q: "Which OpenClaw alternatives are written in Rust?", a: `Rust is the second most popular language in the ecosystem with ${rustProjects.length} projects: ${rustProjects.map(p => p.name).join(', ')}. Rust's memory safety and single-binary distribution make it attractive for agent frameworks.` },
  { q: "Which OpenClaw alternative has the most GitHub stars?", a: `Excluding OpenClaw itself, the most-starred alternative is ${top5[0]?.name} with ${top5[0] ? starsNum(top5[0].slug) : '0'} stars. It is an ultra-minimal Python implementation designed for research.` },
  { q: "What programming languages are OpenClaw alternatives written in?", a: `The ${projectCount} projects span ${langCount} languages: TypeScript (${langCounts.get('typescript') ?? 0}), Python (${langCounts.get('python') ?? 0}), Rust (${langCounts.get('rust') ?? 0}), Go, C, Bash, and Zig.` },
  { q: "Is OpenClaw safe to use?", a: "OpenClaw is open-source under MIT and self-hosted, so your data stays local. Security-focused alternatives like NanoClaw (container isolation), Moltis (zero-unsafe Rust, audit trails), and Carapace (signed WASM plugins) address specific attack surfaces." },
  { q: "What is the most secure OpenClaw clone?", a: "NanoClaw uses OS-level container isolation with minimal surface area. IronClaw and Moltis are Rust-hardened with audit trails. Carapace requires signed WASM plugins. Secure-OpenClaw by Composio offers enterprise-grade controls." },
  { q: "How do OpenClaw alternatives handle permissions?", a: "Models vary: OpenClaw uses skill-based permissions, NanoClaw uses OS-level containers, Moltis logs to an immutable audit trail, Carapace requires signed WASM modules, and SafeClaw uses no LLM at all for deterministic rule-based logic." },
  { q: "OpenClaw vs NanoClaw — which is better?", a: `OpenClaw (${stars('openclaw')} stars) is the full-featured reference with the largest community. NanoClaw (${starsNum('nanoclaw')} stars) strips it to five files with OS-level container isolation, trading features for security. Both are TypeScript/MIT.` },
  { q: "OpenClaw vs ZeroClaw — which should I choose?", a: `Choose OpenClaw for broadest plugin support and community. Choose ZeroClaw for raw performance: sub-10ms startup, 3.4MB binary, under 5MB RAM. ZeroClaw is written in Rust; OpenClaw in TypeScript.` },
  { q: "What's the difference between OpenClaw and its forks?", a: "True forks like Secure-OpenClaw and Moltworker share OpenClaw's codebase. Most alternatives are reimplementations in different languages (Rust, Python, Go, C, Zig) that share the concept but not the code." },
  { q: "What is Shelldex?", a: "Shelldex is a community-maintained directory cataloging every project in the OpenClaw ecosystem. It tracks clones, forks, and reimplementations, comparing them by GitHub stars, language, activity, and health. Formerly known as Clawdex." },
  { q: "How do I submit a project to Shelldex?", a: "Open a pull request on the GitHub repository adding a YAML file to src/data/projects/ with the project's name, description, language, and GitHub URL. A human reviews every submission before merging." },
  { q: "How often is Shelldex updated?", a: "Project data is enriched from the GitHub API on every production build. Star counts, forks, issues, and commits are refreshed each deployment. New projects are added as community submissions are reviewed." },
  { q: "Is Shelldex affiliated with OpenClaw?", a: "No. Shelldex is an independent project by Dave Onkels. It is not affiliated with OpenClaw, Peter Steinberger, or Anthropic. It lists all projects under the same criteria." },
];
---

<Layout
  title={`OpenClaw FAQ: Alternatives, Forks, Security & Comparisons (${new Date().getFullYear()}) | Shelldex`}
  description={`Answers to common questions about OpenClaw alternatives, forks, and comparisons. Learn which projects are fastest, safest, best for self-hosting, and how OpenClaw compares with Hermes Agent, AstrBot, and more.`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "name": "OpenClaw FAQ",
    "description": `Answers to ${projectCount}+ questions about OpenClaw alternatives — which is fastest, most secure, best for self-hosting, and more.`,
    "url": "https://shelldex.com/faq/",
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Shelldex", "item": "https://shelldex.com" },
        { "@type": "ListItem", "position": 2, "name": "FAQ", "item": "https://shelldex.com/faq/" }
      ]
    },
    "mainEntity": faqSchemaItems.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a,
      },
    })),
  })} />

  <!-- Breadcrumb -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
    <nav aria-label="Breadcrumb" class="text-sm text-ledger-faint">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-ledger-red transition-colors">Shelldex</a></li>
        <li class="text-ledger-whisper">/</li>
        <li class="text-ledger-muted">FAQ</li>
      </ol>
    </nav>
  </div>

  <!-- Hero -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-6">
    <h1 class="font-display text-4xl sm:text-5xl font-bold text-ledger-text mb-4">Frequently Asked Questions</h1>
    <p class="text-lg text-ledger-faint max-w-2xl">
      Everything you need to know about <a href="/projects/openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">OpenClaw</a>, its growing ecosystem of alternatives, and how Shelldex tracks them all.
    </p>
    <p class="text-sm text-ledger-faint max-w-2xl mt-4">
      For the two comparison queries people actually keep asking, start here: <a href="/compare/hermes-vs-openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">Hermes Agent vs OpenClaw</a> and <a href="/compare/astrbot-vs-openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">AstrBot vs OpenClaw</a>.
    </p>
  </div>

  <!-- Table of Contents -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="rounded-xl bg-ledger-surface border border-ledger-border p-6">
      <h2 class="font-display text-lg font-semibold text-ledger-text mb-4">Jump to a section</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2 text-sm">
        <li><a href="#general" class="text-ledger-red hover:text-ledger-coral transition-colors">General</a></li>
        <li><a href="#technical" class="text-ledger-red hover:text-ledger-coral transition-colors">Technical</a></li>
        <li><a href="#security" class="text-ledger-red hover:text-ledger-coral transition-colors">Security</a></li>
        <li><a href="#comparisons" class="text-ledger-red hover:text-ledger-coral transition-colors">Comparisons</a></li>
        <li><a href="#ecosystem-shelldex" class="text-ledger-red hover:text-ledger-coral transition-colors">Ecosystem &amp; Shelldex</a></li>
      </ul>
    </div>
  </div>

  <!-- FAQ Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 space-y-16">

    <!-- ============================================================ -->
    <!-- General -->
    <!-- ============================================================ -->
    <section id="general">
      <h2 class="font-display text-3xl font-bold text-ledger-text mb-10 pb-4 border-b border-ledger-border">General</h2>

      <div class="space-y-12">
        <!-- Q1 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">What is OpenClaw?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              <a href="/projects/openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">OpenClaw</a> is a self-hosted, open-source personal AI super-agent platform created by Peter Steinberger. It is written in TypeScript, released under the MIT license, and has accumulated over {starsNum('openclaw')} GitHub stars since its launch. The project began life as a WhatsApp relay bot in November 2025 and went through several name changes &mdash; Clawd, Clawdis, Clawdbot, Moltbot &mdash; before settling on OpenClaw in late January 2026.
            </p>
            <p>
              At its core, OpenClaw gives you a personal AI agent that can interact with your tools, files, and services on your behalf. It runs on your own hardware, keeping your data local by default. The project's rapid growth has spawned an entire ecosystem of clones, forks, and reimplementations, which is exactly what <a href="/" class="text-ledger-red hover:text-ledger-coral transition-colors">Shelldex</a> exists to catalog.
            </p>
            <p>
              You can explore the original project on its <a href="/projects/openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">Shelldex profile page</a> or view the full ranking on the <a href="/leaderboard/" class="text-ledger-red hover:text-ledger-coral transition-colors">leaderboard</a>.
            </p>
          </div>
        </div>

        <!-- Q2 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">What are the best OpenClaw alternatives?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              The best alternative depends on your priorities. By raw popularity, the top five projects by GitHub stars are <a href="/projects/openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">OpenClaw</a> ({stars('openclaw')}), <a href="/projects/nanobot/" class="text-ledger-red hover:text-ledger-coral transition-colors">Nanobot</a> ({stars('nanobot')}), <a href="/projects/zeroclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">ZeroClaw</a> ({stars('zeroclaw')}), <a href="/projects/picoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">PicoClaw</a> ({stars('picoclaw')}), and <a href="/projects/astrbot/" class="text-ledger-red hover:text-ledger-coral transition-colors">AstrBot</a> ({stars('astrbot')}). Each takes a different approach: Nanobot is a research-focused Python implementation in 4,000 lines, ZeroClaw is a Rust-based runtime with sub-10ms startup, and PicoClaw targets embedded hardware like $10 RISC-V boards.
            </p>
            <p>
              If security is your primary concern, look at <a href="/projects/nanoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">NanoClaw</a> ({stars('nanoclaw')} stars, OS-level container isolation), <a href="/projects/ironclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">IronClaw</a> (Rust-hardened privacy fortress), or <a href="/projects/moltis/" class="text-ledger-red hover:text-ledger-coral transition-colors">Moltis</a> (zero-unsafe Rust with full audit trails). For cloud-native deployments, <a href="/projects/moltworker/" class="text-ledger-red hover:text-ledger-coral transition-colors">Moltworker</a> runs on Cloudflare Workers. Check the <a href="/leaderboard/" class="text-ledger-red hover:text-ledger-coral transition-colors">leaderboard</a> for the full ranked list.
            </p>
          </div>
        </div>

        <!-- Q3 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">How many OpenClaw alternatives exist?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              Shelldex currently tracks <strong class="text-ledger-text">{projectCount} projects</strong> across the OpenClaw ecosystem. That number includes the original OpenClaw itself, direct forks, clean-room reimplementations in different languages, and inspired projects that have taken the personal AI agent concept in new directions.
            </p>
            <p>
              The ecosystem is still growing rapidly. New projects surface weekly, and the <a href="/submit/" class="text-ledger-red hover:text-ledger-coral transition-colors">submission page</a> is open for anyone to add a project they have found or built. Browse the full <a href="/" class="text-ledger-red hover:text-ledger-coral transition-colors">directory</a> to see every tracked project at a glance.
            </p>
          </div>
        </div>

        <!-- Q4 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">What is the OpenClaw ecosystem?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              The OpenClaw ecosystem refers to the constellation of projects that have emerged around the original OpenClaw personal AI agent. It includes direct forks, language ports, security-hardened variants, minimal reimplementations, cloud-hosted versions, and entirely new frameworks that cite OpenClaw as their primary inspiration.
            </p>
            <p>
              Projects in the ecosystem span {langCount} programming languages &mdash; TypeScript, Python, Rust, Go, C, Bash, and Zig &mdash; and range from <a href="/projects/bashobot/" class="text-ledger-red hover:text-ledger-coral transition-colors">BashoBot</a> (a pure Bash implementation) to production-grade platforms like <a href="/projects/openfang/" class="text-ledger-red hover:text-ledger-coral transition-colors">OpenFang</a> (137,000 lines of Rust). Some focus on embedded hardware, others on enterprise cloud, and still others on security research. The <a href="/analysis/" class="text-ledger-red hover:text-ledger-coral transition-colors">analysis page</a> breaks down the ecosystem's language distribution, activity trends, and growth patterns.
            </p>
          </div>
        </div>

        <!-- Q5 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">Is OpenClaw free and open source?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              Yes. <a href="/projects/openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">OpenClaw</a> is released under the MIT license, one of the most permissive open-source licenses available. You can use, modify, and redistribute it freely, including in commercial products. The full source code is hosted on GitHub.
            </p>
            <p>
              Most projects in the ecosystem also use permissive licenses. MIT is the most common, followed by Apache 2.0. A few alternatives use stronger copyleft licenses &mdash; for instance, <a href="/projects/tinyclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">TinyClaw</a> uses GPL-3.0 and <a href="/projects/astrbot/" class="text-ledger-red hover:text-ledger-coral transition-colors">AstrBot</a> uses AGPL-3.0. You can filter by license on the <a href="/leaderboard/" class="text-ledger-red hover:text-ledger-coral transition-colors">leaderboard</a> to find projects that match your licensing requirements.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Technical -->
    <!-- ============================================================ -->
    <section id="technical">
      <h2 class="font-display text-3xl font-bold text-ledger-text mb-10 pb-4 border-b border-ledger-border">Technical</h2>

      <div class="space-y-12">
        <!-- Q6 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">What is the lightest OpenClaw alternative?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              The lightest alternatives depend on what you mean by "light." In terms of resource footprint, <a href="/projects/zeroclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">ZeroClaw</a> ships as a single 3.4MB Rust binary that starts in under 10 milliseconds and uses less than 5MB of RAM. <a href="/projects/picoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">PicoClaw</a> goes even further, running on $10 RISC-V boards with under 10MB of RAM and a one-second boot time.
            </p>
            <p>
              In terms of code complexity, <a href="/projects/bashobot/" class="text-ledger-red hover:text-ledger-coral transition-colors">BashoBot</a> is the absolute minimum: a personal AI assistant built entirely in Bash using only standard Unix utilities like <code class="font-mono text-sm bg-ledger-red-bg/50 px-1.5 py-0.5 rounded">curl</code>, <code class="font-mono text-sm bg-ledger-red-bg/50 px-1.5 py-0.5 rounded">jq</code>, and <code class="font-mono text-sm bg-ledger-red-bg/50 px-1.5 py-0.5 rounded">base64</code>. No Node.js, no Python, no compiled runtimes. <a href="/projects/tinyclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">TinyClaw</a> and <a href="/projects/microclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">MicroClaw</a> also target the minimal end of the spectrum, with MicroClaw adding Rust's memory safety guarantees.
            </p>
          </div>
        </div>

        <!-- Q7 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">Can you run an OpenClaw alternative on a Raspberry Pi?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              Absolutely. Several projects in the ecosystem are specifically designed for resource-constrained hardware. <a href="/projects/picoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">PicoClaw</a> was built from the ground up for embedded boards &mdash; it runs on $10 RISC-V hardware with less than 10MB of RAM, so a Raspberry Pi is more than capable. <a href="/projects/zeroclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">ZeroClaw</a>'s 3.4MB binary and sub-5MB RAM usage also make it an excellent fit for any Pi model.
            </p>
            <p>
              <a href="/projects/bashobot/" class="text-ledger-red hover:text-ledger-coral transition-colors">BashoBot</a> is another strong candidate since it requires only Bash 3.2+ and standard Unix tools &mdash; no heavy runtimes to install. For Rust enthusiasts, <a href="/projects/microclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">MicroClaw</a> and <a href="/projects/ironclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">IronClaw</a> both compile to native ARM binaries. The main bottleneck on a Pi will be the LLM inference layer, not the agent framework itself, so pairing a lightweight agent with a cloud-hosted model API keeps resource usage manageable.
            </p>
          </div>
        </div>

        <!-- Q8 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">Which OpenClaw alternatives are written in Rust?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              Rust is the second most popular language in the ecosystem after TypeScript, with {rustProjects.length} projects currently tracked by Shelldex. They span a wide range of use cases:
            </p>
            <ul class="list-disc list-inside space-y-2 pl-2">
              {rustProjects.map(p => (
                <li><a href={`/projects/${p.slug}/`} class="text-ledger-red hover:text-ledger-coral transition-colors">{p.name}</a> &mdash; {p.tagline}</li>
              ))}
            </ul>
            <p>
              Rust's compile-time memory safety, absence of garbage collection pauses, and single-binary distribution make it particularly attractive for agent frameworks where security and performance matter. Visit the <a href="/leaderboard/" class="text-ledger-red hover:text-ledger-coral transition-colors">leaderboard</a> to sort all projects by language.
            </p>
          </div>
        </div>

        <!-- Q9 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">Which OpenClaw alternative has the most GitHub stars?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              Excluding the original OpenClaw ({stars('openclaw')} stars), the most-starred alternative is <a href={`/projects/${top5[0].slug}/`} class="text-ledger-red hover:text-ledger-coral transition-colors">{top5[0].name}</a> with {starsNum(top5[0].slug)} stars. Nanobot is an ultra-minimal Python implementation designed for research and experimentation &mdash; just 4,000 lines of code that prioritize readability over feature density.
            </p>
            <p>
              Close behind are <a href="/projects/zeroclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">ZeroClaw</a> and <a href="/projects/picoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">PicoClaw</a>, each with around {starsNum('zeroclaw')} and {starsNum('picoclaw')} stars respectively. Rounding out the top five alternatives are <a href="/projects/astrbot/" class="text-ledger-red hover:text-ledger-coral transition-colors">AstrBot</a> ({stars('astrbot')}) and <a href="/projects/aionui/" class="text-ledger-red hover:text-ledger-coral transition-colors">AionUi</a> ({stars('aionui')}). The <a href="/leaderboard/" class="text-ledger-red hover:text-ledger-coral transition-colors">leaderboard</a> provides real-time rankings with seven-day star growth trends to help you track which projects are gaining momentum fastest.
            </p>
          </div>
        </div>

        <!-- Q10 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">What programming languages are OpenClaw alternatives written in?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              The {projectCount} projects tracked by Shelldex span {langCount} programming languages. TypeScript leads with {langCounts.get('typescript') ?? 0} projects, reflecting the ecosystem's web-first origins (OpenClaw itself is TypeScript). Python is next with {langCounts.get('python') ?? 0} projects, favored by the research and automation communities. Rust has {langCounts.get('rust') ?? 0} projects, driven by developers who prioritize memory safety and performance.
            </p>
            <p>
              Go accounts for {langCounts.get('go') ?? 0} projects (including <a href="/projects/picoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">PicoClaw</a>), while C has {langCounts.get('c') ?? 0}, Bash has {langCounts.get('bash') ?? 0}, and Zig has {langCounts.get('zig') ?? 0}. The C project targets bare-metal performance, <a href="/projects/bashobot/" class="text-ledger-red hover:text-ledger-coral transition-colors">BashoBot</a> proves that a personal AI agent can run in pure shell script, and the Zig entry explores systems-level agent development without the complexity of C++. For a visual breakdown of language distribution across the ecosystem, see the <a href="/analysis/" class="text-ledger-red hover:text-ledger-coral transition-colors">analysis page</a>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Security -->
    <!-- ============================================================ -->
    <section id="security">
      <h2 class="font-display text-3xl font-bold text-ledger-text mb-10 pb-4 border-b border-ledger-border">Security</h2>

      <div class="space-y-12">
        <!-- Q11 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">Is OpenClaw safe to use?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              OpenClaw is open-source software under the MIT license, and its code is publicly auditable on GitHub. Because it is self-hosted, your data stays on your own machine by default rather than being routed through a third-party cloud. That said, like any software that interacts with LLM APIs and executes actions on your behalf, it requires trust in the code you run and the plugins you install.
            </p>
            <p>
              The community has taken security seriously. Several dedicated security-focused alternatives have appeared specifically to address potential attack surfaces. <a href="/projects/nanoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">NanoClaw</a> uses OS-level container isolation, <a href="/projects/moltis/" class="text-ledger-red hover:text-ledger-coral transition-colors">Moltis</a> enforces zero-unsafe Rust with a full audit trail, and <a href="/projects/carapace/" class="text-ledger-red hover:text-ledger-coral transition-colors">Carapace</a> requires signed WASM plugins. If security is a priority, these hardened alternatives are worth evaluating alongside the original.
            </p>
          </div>
        </div>

        <!-- Q12 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">What is the most secure OpenClaw clone?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              Several projects compete for this title, each with a different security philosophy. <a href="/projects/nanoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">NanoClaw</a> takes a minimalism-first approach: five files, one process, OS-level container isolation. By reducing the surface area to the absolute minimum, there is less to exploit. It has {starsNum('nanoclaw')} stars and is one of the most battle-tested security alternatives.
            </p>
            <p>
              On the Rust side, <a href="/projects/ironclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">IronClaw</a> is a privacy-focused implementation with security hardening baked into its architecture. <a href="/projects/moltis/" class="text-ledger-red hover:text-ledger-coral transition-colors">Moltis</a> takes it further with zero-unsafe Rust and a complete audit trail for every agent action. <a href="/projects/carapace/" class="text-ledger-red hover:text-ledger-coral transition-colors">Carapace</a> adds signed WASM plugins and strict local-first defaults, preventing any untrusted code from executing without explicit cryptographic approval.
            </p>
            <p>
              For users who want a corporate-backed option, <a href="/projects/secure-openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">Secure-OpenClaw</a> by Composio offers a security-hardened fork with 500+ app integrations and enterprise-grade controls. The right choice depends on whether you prioritize minimal attack surface, memory safety, audit compliance, or managed security infrastructure.
            </p>
          </div>
        </div>

        <!-- Q13 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">How do OpenClaw alternatives handle permissions?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              Permission models vary significantly across the ecosystem. The original <a href="/projects/openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">OpenClaw</a> uses a skill-based permission system where each plugin declares the capabilities it needs, and the user approves or denies access. This is the most common pattern, and many forks inherit it directly.
            </p>
            <p>
              Security-focused alternatives go further. <a href="/projects/nanoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">NanoClaw</a> runs each agent in an OS-level container, enforcing isolation at the kernel level rather than relying on application-layer checks. <a href="/projects/moltis/" class="text-ledger-red hover:text-ledger-coral transition-colors">Moltis</a> logs every action to an immutable audit trail, so you can retroactively inspect exactly what your agent did and why. <a href="/projects/carapace/" class="text-ledger-red hover:text-ledger-coral transition-colors">Carapace</a> requires plugins to be signed WASM modules, ensuring that only cryptographically verified code can run.
            </p>
            <p>
              For zero-trust environments, <a href="/projects/safeclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">SafeClaw</a> takes the most radical approach: it uses no LLM at all, relying entirely on deterministic rule-based logic. This eliminates the entire class of prompt injection and hallucination-based permission bypasses. The trade-off is reduced flexibility, but the security guarantee is absolute.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Comparisons -->
    <!-- ============================================================ -->
    <section id="comparisons">
      <h2 class="font-display text-3xl font-bold text-ledger-text mb-10 pb-4 border-b border-ledger-border">Comparisons</h2>

      <div class="space-y-12">
        <!-- Q14 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">OpenClaw vs NanoClaw &mdash; which is better?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              It depends on your priorities. <a href="/projects/openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">OpenClaw</a> is the full-featured reference implementation with {stars('openclaw')} stars, an enormous plugin ecosystem, and the largest community. If you want maximum functionality, the widest range of integrations, and the most community support, OpenClaw is the default choice.
            </p>
            <p>
              <a href="/projects/nanoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">NanoClaw</a> strips that down to five files and one process, trading features for security and simplicity. It uses OS-level container isolation and has accumulated over {starsNum('nanoclaw')} stars from developers who specifically value its security-first, radically minimal approach. If you do not need OpenClaw's full plugin surface and prefer a smaller, more auditable codebase, NanoClaw is the stronger choice.
            </p>
            <p>
              Both are written in TypeScript and released under the MIT license, so switching between them does not require learning a new language or navigating license restrictions. For a side-by-side breakdown, see the <a href="/compare/" class="text-ledger-red hover:text-ledger-coral transition-colors">comparison tool</a>.
            </p>
          </div>
        </div>

        <!-- Q15 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">OpenClaw vs ZeroClaw &mdash; which should I choose?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              <a href="/projects/openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">OpenClaw</a> and <a href="/projects/zeroclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">ZeroClaw</a> are fundamentally different projects that happen to solve the same problem. OpenClaw is a mature TypeScript platform with a massive ecosystem of plugins and integrations. ZeroClaw is a Rust-native runtime built for raw performance: sub-10ms startup, a 3.4MB binary, and less than 5MB of RAM at runtime.
            </p>
            <p>
              Choose OpenClaw if you need the broadest plugin support, a large community for troubleshooting, and you are comfortable running a Node.js stack. Choose ZeroClaw if you are deploying to resource-constrained environments, need deterministic performance characteristics, or prefer Rust's compile-time safety guarantees. ZeroClaw's {starsNum('zeroclaw')}+ stars show significant community validation of the performance-first approach.
            </p>
            <p>
              Use the <a href="/compare/" class="text-ledger-red hover:text-ledger-coral transition-colors">comparison tool</a> to see how they stack up on stars, activity, releases, and community health.
            </p>
          </div>
        </div>

        <!-- Q16 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">What's the difference between OpenClaw and its forks?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              The term "fork" gets used loosely in this ecosystem. True forks &mdash; projects that share OpenClaw's actual codebase and diverge from it &mdash; include <a href="/projects/secure-openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">Secure-OpenClaw</a> by Composio and <a href="/projects/moltworker/" class="text-ledger-red hover:text-ledger-coral transition-colors">Moltworker</a> by Cloudflare. These inherit OpenClaw's TypeScript foundation and modify it for specific use cases (security hardening and serverless deployment, respectively).
            </p>
            <p>
              Most other "alternatives" are better described as reimplementations or inspired projects. <a href="/projects/zeroclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">ZeroClaw</a>, <a href="/projects/ironclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">IronClaw</a>, and <a href="/projects/moltis/" class="text-ledger-red hover:text-ledger-coral transition-colors">Moltis</a> are written from scratch in Rust. <a href="/projects/nanobot/" class="text-ledger-red hover:text-ledger-coral transition-colors">Nanobot</a> is a clean-room Python implementation for research. <a href="/projects/picoclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">PicoClaw</a> targets a completely different platform (embedded Go on RISC-V boards). These projects share OpenClaw's concept of a personal AI agent but not its code.
            </p>
            <p>
              Shelldex tracks all of these under one umbrella because the ecosystem is defined by the idea, not the codebase. The <a href="/" class="text-ledger-red hover:text-ledger-coral transition-colors">directory</a> labels each project's category so you can quickly distinguish forks from ports from original works.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Ecosystem & Shelldex -->
    <!-- ============================================================ -->
    <section id="ecosystem-shelldex">
      <h2 class="font-display text-3xl font-bold text-ledger-text mb-10 pb-4 border-b border-ledger-border">Ecosystem &amp; Shelldex</h2>

      <div class="space-y-12">
        <!-- Q17 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">What is Shelldex?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              Shelldex is a community-maintained directory that catalogs every project in the OpenClaw ecosystem. It tracks clones, forks, reimplementations, and inspired projects &mdash; comparing them by GitHub stars, programming language, activity, and community health. Think of it as a species registry for every shell in the sea.
            </p>
            <p>
              The site was formerly known as Clawdex (at theclawdex.com) before rebranding in February 2026. It is built with Astro and Tailwind CSS, hosted on GitHub Pages, and the entire codebase is open source. Every project listing is a YAML file in the repository, and enrichment data (stars, forks, recent commits) is pulled from the GitHub API at build time. Read more on the <a href="/about/" class="text-ledger-red hover:text-ledger-coral transition-colors">about page</a>.
            </p>
          </div>
        </div>

        <!-- Q18 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">How do I submit a project to Shelldex?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              Head to the <a href="/submit/" class="text-ledger-red hover:text-ledger-coral transition-colors">submit page</a> for full instructions. The short version: every project in Shelldex is a YAML file in the <a href="https://github.com/daveonkels/clawdex" class="text-ledger-red hover:text-ledger-coral transition-colors" target="_blank" rel="noopener noreferrer">GitHub repository</a>. To add a project, open a pull request that adds a new YAML file to <code class="font-mono text-sm bg-ledger-red-bg/50 px-1.5 py-0.5 rounded">src/data/projects/</code> with the project's name, slug, description, language, GitHub URL, and status.
            </p>
            <p>
              A human reviews every submission before it merges. The project must be an OpenClaw-inspired agentic framework &mdash; not a workflow, tutorial, or skill/plugin. Once merged, the site rebuilds automatically and the project appears in the <a href="/" class="text-ledger-red hover:text-ledger-coral transition-colors">directory</a>, <a href="/leaderboard/" class="text-ledger-red hover:text-ledger-coral transition-colors">leaderboard</a>, and comparison tools. No accounts, no forms, no approval committees. Just git.
            </p>
          </div>
        </div>

        <!-- Q19 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">How often is Shelldex updated?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              Project data is enriched from the GitHub API on every production build. This means star counts, fork counts, open issues, latest releases, and commit timestamps are refreshed each time the site is deployed. Deployments happen regularly as new projects are submitted and reviewed.
            </p>
            <p>
              New project additions depend on community submissions and maintainer curation. The ecosystem is growing quickly &mdash; Shelldex went from zero to {projectCount} tracked projects within its first weeks. If you spot a project that should be listed, the <a href="/submit/" class="text-ledger-red hover:text-ledger-coral transition-colors">submission process</a> is open and straightforward.
            </p>
          </div>
        </div>

        <!-- Q20 -->
        <div>
          <h3 class="font-display text-xl font-semibold text-ledger-text mb-4">Is Shelldex affiliated with OpenClaw?</h3>
          <div class="text-ledger-muted leading-relaxed space-y-4">
            <p>
              No. Shelldex is an independent, community-maintained project created by <a href="https://onk.io" class="text-ledger-red hover:text-ledger-coral transition-colors" target="_blank" rel="noopener noreferrer">Dave Onkels</a>. It is not affiliated with OpenClaw, Peter Steinberger, or Anthropic. The directory exists to serve the community by mapping the ecosystem, not to endorse or rank any particular project.
            </p>
            <p>
              Shelldex lists <a href="/projects/openclaw/" class="text-ledger-red hover:text-ledger-coral transition-colors">OpenClaw</a> alongside every other project in the ecosystem under the same criteria: GitHub data, language, license, and activity. The <a href="/about/" class="text-ledger-red hover:text-ledger-coral transition-colors">about page</a> has more details on the project's origins, naming history, and editorial approach.
            </p>
          </div>
        </div>
      </div>
    </section>

