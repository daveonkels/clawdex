---
import { formatStars } from '../lib/projects';

interface Props {
  name: string;
  slug: string;
  tagline: string;
  description: string;
  language: string;
  category: string[];
  github?: string;
  status: string;
  tier: number;
  highlight: string;
  emoji: string;
  stars?: number;
  added?: string;
}

const { name, tagline, language, category, github, status, tier, highlight, emoji, stars, added } = Astro.props;

const languageColors: Record<string, { bg: string; text: string; border: string }> = {
  typescript: { bg: 'bg-blue-500/10', text: 'text-blue-400', border: 'border-blue-500/20' },
  rust: { bg: 'bg-orange-500/10', text: 'text-orange-400', border: 'border-orange-500/20' },
  python: { bg: 'bg-yellow-500/10', text: 'text-yellow-400', border: 'border-yellow-500/20' },
  go: { bg: 'bg-cyan-500/10', text: 'text-cyan-400', border: 'border-cyan-500/20' },
  c: { bg: 'bg-gray-500/10', text: 'text-gray-400', border: 'border-gray-500/20' },
  multi: { bg: 'bg-purple-500/10', text: 'text-purple-400', border: 'border-purple-500/20' },
};

const lang = languageColors[language] || languageColors.multi;

const statusColors: Record<string, string> = {
  active: 'text-green-400',
  experimental: 'text-yellow-400',
  archived: 'text-gray-500',
};

const tierLabels: Record<number, string> = {
  1: 'Clone',
  2: 'Ecosystem',
  3: 'Inspired',
};
---

<article
  class="card-glow rounded-xl bg-ocean-card border border-white/5 p-6 flex flex-col h-full"
  data-language={language}
  data-category={category.join(',')}
  data-tier={tier}
  data-status={status}
  data-stars={stars ?? 0}
  data-name={name}
  data-added={added ?? ''}
>
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-center gap-3">
      <span class={`text-3xl ${name === 'OpenClaw' ? 'og-lobster' : ''}`}>{emoji}</span>
      <div>
        <h3 class="font-display font-bold text-white text-lg leading-tight">{name}</h3>
        <p class="text-sm text-gray-500 mt-0.5">{tagline}</p>
      </div>
    </div>
    {stars !== undefined && stars > 0 && (
      <a href={github ? `https://github.com/${github}` : '#'} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 text-sm text-yellow-500/80 hover:text-yellow-400 transition-colors flex-shrink-0 ml-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.896l-7.416 3.517 1.48-8.279L0 9.306l8.332-1.151z"/></svg>
        <span class="font-mono text-xs">{formatStars(stars)}</span>
      </a>
    )}
  </div>

  <p class="text-sm text-gray-400 leading-relaxed mb-4 flex-1">{highlight}</p>

  <div class="flex flex-wrap gap-2 mb-4">
    {language !== 'multi' && (
      <span class={`badge-language border ${lang.bg} ${lang.text} ${lang.border}`}>
        {language}
      </span>
    )}
    <span class={`badge-language border border-white/10 bg-white/5 ${statusColors[status]}`}>
      {status}
    </span>
    <span class="badge-language border border-white/10 bg-white/5 text-gray-500">
      Tier {tier}: {tierLabels[tier]}
    </span>
  </div>

  <div class="flex flex-wrap gap-1.5 mb-4">
    {category.map((cat: string) => (
      <span class="text-xs text-gray-600 bg-white/[0.03] rounded px-2 py-0.5">
        {cat}
      </span>
    ))}
  </div>

  {github && (
    <a
      href={`https://github.com/${github}`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-biolum transition-colors mt-auto pt-3 border-t border-white/5"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      <span>{github}</span>
      <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </a>
  )}
</article>
