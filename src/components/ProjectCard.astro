---
import { formatStars } from '../lib/projects';

interface Props {
  name: string;
  slug: string;
  tagline: string;
  description: string;
  language: string;
  category: string[];
  github?: string;
  status: string;
  highlight: string;
  emoji: string;
  stars?: number;
  added?: string;
  platform?: string[];
  requires_llm?: boolean;
  mcp_support?: boolean;
}

const { name, slug, tagline, language, category, github, status, highlight, emoji, stars, added, platform, requires_llm, mcp_support } = Astro.props;

const langDot: Record<string, string> = {
  typescript: 'bg-blue-500', rust: 'bg-orange-500', python: 'bg-yellow-500',
  go: 'bg-cyan-600', c: 'bg-gray-500', bash: 'bg-green-600',
  zig: 'bg-amber-500', javascript: 'bg-yellow-400', kotlin: 'bg-purple-500',
  multi: 'bg-ledger-faint',
};

const statusDot: Record<string, string> = {
  active: 'bg-emerald-500',
  experimental: 'bg-amber-500',
  archived: 'bg-gray-400',
};

---

<article
  class="card-glow rounded-xl bg-ledger-surface border border-ledger-border p-6 flex flex-col h-full"
  data-language={language}
  data-category={category.join(',')}
  data-status={status}
  data-stars={stars ?? 0}
  data-name={name}
  data-added={added ?? ''}
  data-platform={platform?.join(',') ?? ''}
>
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-center gap-3">
      <span class={`text-3xl ${name === 'OpenClaw' ? 'og-lobster' : ''}`}>{emoji}</span>
      <div>
        <a href={`/projects/${slug}/`} class="font-display font-bold text-ledger-text text-lg leading-tight hover:text-ledger-red transition-colors">{name}</a>
        <p class="text-sm text-ledger-faint mt-0.5">{tagline}</p>
      </div>
    </div>
    {stars !== undefined && stars > 0 && (
      <a href={github ? `https://github.com/${github}` : '#'} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 text-sm text-ledger-coral hover:text-amber-700 transition-colors flex-shrink-0 ml-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.896l-7.416 3.517 1.48-8.279L0 9.306l8.332-1.151z"/></svg>
        <span class="font-mono text-xs">{formatStars(stars)}</span>
      </a>
    )}
  </div>

  <p class="text-sm text-ledger-faint leading-relaxed mb-4 flex-1">{highlight}</p>

  <div class="flex flex-wrap gap-1.5 mb-4">
    {language !== 'multi' && (
      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-ledger-surface border border-ledger-border text-xs font-medium text-ledger-text">
        <span class={`w-1.5 h-1.5 rounded-full ${langDot[language] || 'bg-ledger-faint'}`}></span>
        {language}
      </span>
    )}
    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-ledger-surface border border-ledger-border text-xs font-medium text-ledger-text">
      <span class={`w-1.5 h-1.5 rounded-full ${statusDot[status] || 'bg-gray-400'}`}></span>
      {status}
    </span>
    {requires_llm === false && (
      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-ledger-surface border border-ledger-border text-xs font-medium text-emerald-700">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        zero-cost
      </span>
    )}
    {mcp_support === true && (
      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-ledger-surface border border-ledger-border text-xs font-medium text-purple-700">
        <span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>
        MCP
      </span>
    )}
  </div>

  <div class="flex flex-wrap gap-1.5 mb-4">
    {category.map((cat: string) => (
      <span class="text-xs text-ledger-faint bg-ledger-red-bg/30 rounded px-2 py-0.5">
        {cat}
      </span>
    ))}
  </div>

  {github && (
    <a
      href={`https://github.com/${github}`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-sm text-ledger-faint hover:text-ledger-red transition-colors mt-auto pt-3 border-t border-ledger-border"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      <span>{github}</span>
      <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </a>
  )}
</article>
