---
interface Props {
  projectCount: number;
}
const { projectCount } = Astro.props;
---

<section class="relative overflow-hidden pt-14 sm:pt-[5.4rem] pb-6 sm:pb-10">
  <!-- Periodic bioluminescent flashes — injected by script below -->
  <div id="bio-flashes" class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true"></div>

  <!-- Background gradient orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full bg-lobster/10 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full bg-biolum/8 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-biolum/3 blur-3xl"></div>
  </div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-display text-4xl sm:text-6xl lg:text-7xl font-bold text-white mb-6 tracking-tight">
      Every <span class="text-transparent bg-clip-text bg-gradient-to-r from-lobster to-coral">shell</span> in the sea
    </h1>

    <p id="hero-tagline" class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      The complete registry of <span class="text-biolum font-medium">OpenClaw</span> clones, forks, derivatives, and inspired projects.
      Discover the crustacean ecosystem.
    </p>

    <!-- SEO descriptor — visually hidden, still crawled -->
    <p class="sr-only">OpenClaw-inspired agentic projects — not workflows, not tutorials. The personal agent universe, cataloged.</p>

    <script is:inline>
      (function() {
        const taglines = [
          'The complete registry of <span class="text-biolum font-medium">OpenClaw</span> clones, forks, derivatives, and inspired projects. Discover the crustacean ecosystem.',
          'Five name changes. Forty-three thousand forks. One crustacean.',
          'A directory of projects that exist because one lobster couldn\'t sit still.',
          'Cataloging the ecosystem before it molts again.',
          'None of these are affiliated with actual lobsters. Probably.',
          'Somebody had to keep track. We drew the short claw.',
        ];
        const el = document.getElementById('hero-tagline');
        if (el) el.innerHTML = taglines[Math.floor(Math.random() * taglines.length)];
      })();
    </script>

    <div class="flex flex-col items-center gap-4">
      <a href="#directory" class="group inline-flex items-center gap-2 px-6 py-3 bg-biolum text-ocean font-semibold rounded-lg hover:bg-biolum-light transition-all duration-200 shadow-lg shadow-biolum/20">
        Browse Directory
        <svg class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </a>
      <a href="/submit" class="text-sm text-gray-500 hover:text-biolum transition-colors">
        Know a project we're missing? Submit it →
      </a>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var container = document.getElementById('bio-flashes');
    if (!container) return;

    // Spawn a soft bioluminescent orb at a random position, fade it in then out
    function spawnFlash() {
      var el = document.createElement('div');
      var size = 100 + Math.random() * 225; // 100–325px
      var x = 5 + Math.random() * 90;      // 5–95% from left
      var y = 5 + Math.random() * 90;      // 5–95% from top
      // Alternate between teal and a very faint coral
      var teal = Math.random() > 0.25;
      var color = teal ? '0,212,170' : '212,100,67';
      var peak = teal ? (0.12 + Math.random() * 0.10) : (0.06 + Math.random() * 0.05);

      el.style.cssText = [
        'position:absolute',
        'border-radius:50%',
        'pointer-events:none',
        'width:' + size + 'px',
        'height:' + size + 'px',
        'left:' + x + '%',
        'top:' + y + '%',
        'transform:translate(-50%,-50%)',
        'background:radial-gradient(circle, rgba(' + color + ',' + peak + ') 0%, transparent 70%)',
        'opacity:0',
        'transition:opacity 1.8s ease-in-out',
      ].join(';');

      container.appendChild(el);

      // Fade in
      requestAnimationFrame(function () {
        requestAnimationFrame(function () { el.style.opacity = '1'; });
      });

      // Fade out after a hold
      var hold = 1200 + Math.random() * 1800;
      setTimeout(function () {
        el.style.opacity = '0';
        setTimeout(function () { el.parentNode && el.parentNode.removeChild(el); }, 1900);
      }, hold);
    }

    // Stagger the initial bursts so the page doesn't light up all at once
    function scheduleNext() {
      var delay = 1350 + Math.random() * 2250; // every 1.35–3.6s
      setTimeout(function () {
        spawnFlash();
        scheduleNext();
      }, delay);
    }

    // First flash after a short settle
    setTimeout(function () { spawnFlash(); scheduleNext(); }, 800);
  })();
</script>
