---
interface Props {
  projectCount: number;
}
const { projectCount } = Astro.props;
---

<section class="relative overflow-hidden py-20 sm:py-28">
  <!-- Lobster claw peeking in from right -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none select-none animate-claw-sway z-10"
       style="transform-origin: right center;" aria-hidden="true">
    <svg width="220" height="380" viewBox="0 0 280 480" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <radialGradient id="clawGlow" cx="40%" cy="50%" r="60%">
          <stop offset="0%" stop-color="#00d4aa" stop-opacity="0.15"/>
          <stop offset="100%" stop-color="#00d4aa" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="clawBody" cx="30%" cy="30%" r="70%">
          <stop offset="0%" stop-color="#e05a3a"/>
          <stop offset="100%" stop-color="#b83520"/>
        </radialGradient>
        <filter id="clawDropShadow">
          <feDropShadow dx="-4" dy="0" stdDeviation="10" flood-color="#00d4aa" flood-opacity="0.2"/>
        </filter>
      </defs>

      <!-- Bioluminescent glow halo -->
      <ellipse cx="160" cy="240" rx="160" ry="200" fill="url(#clawGlow)"/>

      <!-- ARM — extends off the right edge -->
      <path d="M 280 420 Q 265 390 248 365 Q 235 342 232 318 L 262 310 Q 268 337 282 364 Q 290 390 280 418 Z"
            fill="url(#clawBody)" stroke="#8a2010" stroke-width="2" filter="url(#clawDropShadow)"/>

      <!-- WRIST JOINT -->
      <ellipse cx="244" cy="312" rx="22" ry="18" fill="#c04030" stroke="#7a1808" stroke-width="2"/>

      <!-- PALM — thick stroke trick for the meaty bit -->
      <path d="M 238 298 Q 220 268 204 238 Q 190 210 186 192" stroke="#d04535" stroke-width="52" stroke-linecap="round" fill="none"/>
      <path d="M 238 326 Q 220 354 204 380 Q 190 402 186 420" stroke="#c03e2e" stroke-width="52" stroke-linecap="round" fill="none"/>

      <!-- UPPER FINGER (dactyl) -->
      <path d="M 186 178 Q 164 156 138 134 Q 114 114 88 103 Q 60 92 38 98 Q 18 104 18 120 Q 18 137 42 138 Q 68 140 96 146 Q 124 154 150 170 Q 168 182 182 198 L 186 178 Z"
            fill="url(#clawBody)" stroke="#8a2010" stroke-width="2" filter="url(#clawDropShadow)"/>

      <!-- Upper finger highlight -->
      <path d="M 38 98 Q 22 106 22 120 Q 22 135 42 136 Q 28 134 26 120 Q 26 106 38 98 Z"
            fill="#a83018"/>

      <!-- LOWER FINGER (pollex) -->
      <path d="M 186 434 Q 162 452 136 462 Q 110 470 84 467 Q 56 463 38 450 Q 20 436 22 420 Q 24 405 48 404 Q 74 403 102 412 Q 130 422 158 428 Q 176 432 186 430 L 186 434 Z"
            fill="url(#clawBody)" stroke="#8a2010" stroke-width="2" filter="url(#clawDropShadow)"/>

      <!-- Lower finger tip shade -->
      <path d="M 48 404 Q 26 406 22 420 Q 20 434 38 448 Q 24 436 24 420 Q 26 406 48 404 Z"
            fill="#a83018"/>

      <!-- Palm highlight stripe -->
      <path d="M 238 292 Q 222 264 206 236 Q 195 215 188 198"
            stroke="#e8744a" stroke-width="8" stroke-linecap="round" fill="none" opacity="0.4"/>

      <!-- Segment lines on arm -->
      <path d="M 255 350 Q 243 338 258 332" stroke="#922010" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.8"/>
      <path d="M 262 372 Q 250 360 266 355" stroke="#922010" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.8"/>
      <path d="M 268 395 Q 258 384 272 378" stroke="#922010" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.7"/>

      <!-- Spines on fingers -->
      <circle cx="100" cy="148" r="3.5" fill="#922010" opacity="0.7"/>
      <circle cx="128" cy="158" r="3" fill="#922010" opacity="0.6"/>
      <circle cx="158" cy="172" r="3" fill="#922010" opacity="0.6"/>
      <circle cx="100" cy="410" r="3.5" fill="#922010" opacity="0.7"/>
      <circle cx="130" cy="422" r="3" fill="#922010" opacity="0.6"/>
    </svg>
  </div>

  <!-- Background gradient orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full bg-lobster/10 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full bg-biolum/8 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-biolum/3 blur-3xl"></div>
  </div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-biolum/10 border border-biolum/20 mb-8">
      <span class="w-2 h-2 rounded-full bg-biolum animate-glow-pulse"></span>
      <span class="text-sm font-medium text-biolum sm:hidden">{projectCount} projects cataloged</span>
      <span class="text-sm font-medium text-biolum hidden sm:inline">{projectCount} projects cataloged · 43,800 forks · 3 that actually work</span>
    </div>

    <h1 class="font-display text-4xl sm:text-6xl lg:text-7xl font-bold text-white mb-6 tracking-tight">
      Every <span class="text-transparent bg-clip-text bg-gradient-to-r from-lobster to-coral">shell</span> in the sea
    </h1>

    <p id="hero-tagline" class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      The complete registry of <span class="text-biolum font-medium">OpenClaw</span> clones, forks, derivatives, and inspired projects.
      Discover the crustacean ecosystem.
    </p>
    <p class="text-sm text-gray-600 max-w-xl mx-auto -mt-6 mb-10">
      OpenClaw-inspired agentic projects — not workflows, not tutorials. The personal agent universe, cataloged.
    </p>

    <script is:inline>
      (function() {
        const taglines = [
          'The complete registry of <span class="text-biolum font-medium">OpenClaw</span> clones, forks, derivatives, and inspired projects. Discover the crustacean ecosystem.',
          'Five name changes. Forty-three thousand forks. One crustacean.',
          'A directory of projects that exist because one lobster couldn\'t sit still.',
          'Cataloging the ecosystem before it molts again.',
          'None of these are affiliated with actual lobsters. Probably.',
          'Somebody had to keep track. We drew the short claw.',
        ];
        const el = document.getElementById('hero-tagline');
        if (el) el.innerHTML = taglines[Math.floor(Math.random() * taglines.length)];
      })();
    </script>

    <div class="flex flex-row items-center justify-center gap-3 sm:gap-4">
      <a href="#directory" class="group inline-flex items-center gap-2 px-6 py-3 bg-biolum text-ocean font-semibold rounded-lg hover:bg-biolum-light transition-all duration-200 shadow-lg shadow-biolum/20">
        Browse Directory
        <svg class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </a>
      <a href="/submit" class="inline-flex items-center gap-2 px-6 py-3 border border-white/10 text-gray-300 font-semibold rounded-lg hover:border-lobster/40 hover:text-lobster-light transition-all duration-200">
        Submit a Project
      </a>
    </div>
  </div>
</section>
