# Netlify/Cloudflare Pages _headers file.
# The production deploy (ploi.io + nginx) ignores this; the canonical header
# config lives in the ploi-managed nginx site. This file documents the intended
# headers and auto-configures any headers-aware static host (Netlify, Cloudflare
# Pages, etc.) if the site is ever mirrored there.

/*
  Link: </.well-known/api-catalog>; rel="api-catalog", </openapi.json>; rel="service-desc"; type="application/vnd.oai.openapi+json;version=3.1", </AGENTS.md>; rel="service-doc"; type="text/markdown", </llms.txt>; rel="describedby"; type="text/plain"
  Vary: Accept

/AGENTS.md
  Content-Type: text/markdown; charset=utf-8

/llms.txt
  Content-Type: text/plain; charset=utf-8

/llms-full.txt
  Content-Type: text/plain; charset=utf-8

/openapi.json
  Content-Type: application/vnd.oai.openapi+json;version=3.1

/.well-known/api-catalog
  Content-Type: application/linkset+json

/.well-known/ai-plugin.json
  Content-Type: application/json

/.well-known/mcp.json
  Content-Type: application/json

/api/*
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *

/md/*
  Content-Type: text/markdown; charset=utf-8
